---
import { ViewTransitions } from 'astro:transitions'
import '../styles/global.css'
import '../styles/animations.css'
import { getOrganizationSchema } from '../lib/seo'
import Navigation from '../components/astro/Navigation.astro'
import Footer from '../components/astro/Footer.astro'
import CustomCursor from '../components/astro/CustomCursor.astro'
import CookieConsent from '../components/astro/CookieConsent.astro'
import ScrollProgress from '../components/astro/ScrollProgress.astro'
import BackToTop from '../components/astro/BackToTop.astro'

interface Props {
  title: string
  description: string
  ogImage?: string
  locale?: 'de' | 'en'
  canonicalPath?: string
  schema?: object | object[]
  hideNav?: boolean
  hideFooter?: boolean
}

const {
  title,
  description,
  ogImage = 'https://flexen.app/og/default.jpg',
  locale = 'de',
  canonicalPath = Astro.url.pathname,
  schema,
  hideNav = false,
  hideFooter = false,
} = Astro.props

const siteUrl = 'https://flexen.app'
const canonical = `${siteUrl}${canonicalPath}`
const altLocale = locale === 'de' ? 'en' : 'de'
const pathWithoutLocale = canonicalPath.replace(/^\/(de|en)/, '')

// Map locale-specific slugs to their counterpart
const pathMap: Record<string, string> = {
  '/preise': '/pricing',
  '/pricing': '/preise',
  '/ueber-uns': '/about',
  '/about': '/ueber-uns',
  '/datenschutz': '/privacy',
  '/privacy': '/datenschutz',
  '/impressum': '/imprint',
  '/imprint': '/impressum',
  '/agb': '/terms',
  '/terms': '/agb',
}
const altPath = pathMap[pathWithoutLocale] ?? pathWithoutLocale
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="de" href={`${siteUrl}/de${locale === 'de' ? pathWithoutLocale : altPath}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}/en${locale === 'en' ? pathWithoutLocale : altPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/de${locale === 'de' ? pathWithoutLocale : altPath}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'de' ? 'de_DE' : 'en_US'} />
    <meta property="og:site_name" content="Flexen" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#001622" />

    <!-- Fonts: Preload for LCP -->
    <link rel="preload" href="/fonts/SpaceGrotesk-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Plausible Analytics (cookieless, DSGVO-konform) -->
    {
      import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN && (
        <script
          is:inline
          defer
          data-domain={import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN}
          src={import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT || 'https://plausible.io/js/script.js'}
        />
      )
    }

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(getOrganizationSchema())} />
    {schema && !Array.isArray(schema) && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    {Array.isArray(schema) && schema.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}

    <!-- View Transitions for smooth page navigation -->
    <ViewTransitions />
  </head>
  <body>
    <!-- Skip to content (a11y) -->
    <a
      href="#main-content"
      class="focus:gradient-accent sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:rounded-lg focus:px-4 focus:py-2 focus:font-semibold focus:text-white"
    >
      {locale === 'de' ? 'Zum Inhalt springen' : 'Skip to content'}
    </a>

    <ScrollProgress />
    {!hideNav && <Navigation locale={locale} currentPath={canonicalPath} />}
    <main id="main-content" transition:animate="fade">
      <slot />
    </main>
    {!hideFooter && <Footer locale={locale} />}

    <BackToTop />
    <CookieConsent />
    <CustomCursor />

    <script>
      import { initSmoothScroll } from '../lib/smooth-scroll'
      import { initAllAnimations } from '../lib/animations'

      initSmoothScroll()
      initAllAnimations()
    </script>
  </body>
</html>
