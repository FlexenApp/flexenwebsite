---
import '../styles/global.css'
import '../styles/animations.css'
import { getAppSchema, getOrganizationSchema } from '../lib/seo'
import Navigation from '../components/astro/Navigation.astro'
import Footer from '../components/astro/Footer.astro'
import CustomCursor from '../components/astro/CustomCursor.astro'

interface Props {
  title: string
  description: string
  ogImage?: string
  locale?: 'de' | 'en'
  canonicalPath?: string
  schema?: object | object[]
  hideNav?: boolean
  hideFooter?: boolean
}

const {
  title,
  description,
  ogImage = 'https://flexen.app/og/default.jpg',
  locale = 'de',
  canonicalPath = Astro.url.pathname,
  schema,
  hideNav = false,
  hideFooter = false,
} = Astro.props

const siteUrl = 'https://flexen.app'
const canonical = `${siteUrl}${canonicalPath}`
const altLocale = locale === 'de' ? 'en' : 'de'
const pathWithoutLocale = canonicalPath.replace(/^\/(de|en)/, '')
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="de" href={`${siteUrl}/de${pathWithoutLocale}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}/en${pathWithoutLocale}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/de${pathWithoutLocale}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'de' ? 'de_DE' : 'en_US'} />
    <meta property="og:site_name" content="Flexen" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#001622" />

    <!-- Fonts: Preload for LCP -->
    <link rel="preload" href="/fonts/SpaceGrotesk-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(getOrganizationSchema())} />
    <script type="application/ld+json" set:html={JSON.stringify(getAppSchema())} />
    {schema && !Array.isArray(schema) && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    {Array.isArray(schema) && schema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    {!hideNav && <Navigation locale={locale} currentPath={canonicalPath} />}
    <slot />
    {!hideFooter && <Footer locale={locale} />}

    <CustomCursor />

    <script>
      import { initSmoothScroll } from '../lib/smooth-scroll'
      import { initAllAnimations } from '../lib/animations'

      initSmoothScroll()
      initAllAnimations()
    </script>
  </body>
</html>
