---
import BaseLayout from './BaseLayout.astro'
import NewsletterSignup from '../components/astro/NewsletterSignup.astro'
import { getArticleSchema } from '../lib/seo'

interface Props {
  title: string
  description: string
  date: Date
  category: string
  image?: string
  imageAlt?: string
  locale?: 'de' | 'en'
}

const { title, description, date, category, image, imageAlt: _imageAlt, locale = 'de' } = Astro.props

const formattedDate = date.toLocaleDateString(locale === 'de' ? 'de-DE' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const schema = getArticleSchema({
  title,
  description,
  datePublished: date.toISOString(),
  image,
  url: `https://flexen.co${Astro.url.pathname}`,
})

const categoryLabels: Record<string, string> = {
  ernaehrung: locale === 'de' ? 'Ernährung' : 'Nutrition',
  training: 'Training',
  'ki-tech': locale === 'de' ? 'KI & Tech' : 'AI & Tech',
  erfolgsgeschichten: locale === 'de' ? 'Erfolgsgeschichten' : 'Success Stories',
}
---

<BaseLayout title={`${title} — Flexen Blog`} description={description} locale={locale} schema={schema} ogImage={image}>
  <article class="section pt-32">
    <div class="container">
      <div class="content max-w-3xl">
        <!-- Meta -->
        <div class="mb-6 flex items-center gap-4">
          <span class="bg-flexen-accent/15 text-flexen-accent inline-block rounded-full px-3 py-1 text-xs font-medium">
            {categoryLabels[category] || category}
          </span>
          <time class="text-tertiary text-sm" datetime={date.toISOString()}>
            {formattedDate}
          </time>
        </div>

        <!-- Title -->
        <h1 class="mb-8 text-h1 font-bold">{title}</h1>

        <!-- Content -->
        <div
          class="prose prose-lg [&>p]:text-secondary [&>ul]:text-secondary [&>ol]:text-secondary [&>blockquote]:border-flexen-accent [&>blockquote]:text-secondary [&_a]:text-flexen-accent [&>h3]:text-body [&>p]:text-body max-w-none [&_a]:underline [&_a]:underline-offset-2 [&_code]:rounded [&_code]:bg-slate-100 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-sm [&_strong]:text-text [&>blockquote]:border-l-2 [&>blockquote]:pl-6 [&>blockquote]:italic [&>h2]:mt-12 [&>h2]:mb-4 [&>h2]:text-h3 [&>h2]:font-bold [&>h3]:mt-8 [&>h3]:mb-3 [&>h3]:font-bold [&>ol]:mb-6 [&>ol]:space-y-2 [&>p]:mb-6 [&>p]:leading-relaxed [&>ul]:mb-6 [&>ul]:space-y-2"
        >
          <slot />
        </div>

        <!-- CTA -->
        <div class="mt-16 rounded-2xl border border-border bg-bg-soft p-8 text-center shadow-sm">
          <p class="text-body mb-2 font-bold">
            {
              locale === 'de'
                ? 'Tracke deine Ernährung automatisch mit Flexen'
                : 'Track your nutrition automatically with Flexen'
            }
          </p>
          <a
            href={`/${locale}/${locale === 'de' ? 'preise' : 'pricing'}`}
            class="gradient-accent mt-4 inline-flex items-center justify-center rounded-xl px-8 py-3 font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
          >
            {locale === 'de' ? 'Kostenlos starten' : 'Start for free'}
          </a>
        </div>
      </div>
    </div>
  </article>

  <NewsletterSignup locale={locale} variant="card" />
</BaseLayout>
