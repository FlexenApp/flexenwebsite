---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="404 — Seite nicht gefunden"
  description="Diese Seite existiert nicht."
  locale="de"
  canonicalPath="/404"
>
  <section class="section flex min-h-[70vh] items-center justify-center">
    <div class="container">
      <div class="content text-center">
        <span class="text-flexen-accent font-heading mb-4 block text-[length:var(--text-hero)] font-bold">404</span>
        <h1 class="font-heading mb-4 text-[length:var(--text-h2)] font-bold">Seite nicht gefunden</h1>
        <p class="text-secondary mb-8 text-[length:var(--text-body)]">
          Die gesuchte Seite existiert nicht oder wurde verschoben.
        </p>
        <a
          href="/de/"
          class="btn-glow gradient-accent inline-flex items-center justify-center rounded-xl px-8 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
        >
          Zur Startseite
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
