---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Home', url: 'https://flexen.app/en/' },
  { name: 'Privacy Policy', url: 'https://flexen.app/en/privacy' },
])
---

<BaseLayout
  title="Privacy Policy — Flexen"
  description="Privacy policy for the Flexen App website. Information about how we handle your data."
  locale="en"
  canonicalPath="/en/privacy"
  schema={breadcrumbSchema}
>
  <section class="section min-h-screen">
    <div class="container">
      <div class="content max-w-3xl">
        <h1 class="font-heading mb-12 text-h1 font-bold">Privacy Policy</h1>

        <div class="prose prose-invert text-secondary text-body space-y-8">
          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">1. Controller</h2>
            <p>
              The controller for data processing on this website is:<br /><br />
              <strong class="text-white">[Company Name]</strong><br />
              [Street + Number]<br />
              [Postal Code + City], Germany<br />
              Email: <a href="mailto:datenschutz@flexen.app" class="text-flexen-accent hover:underline"
                >datenschutz@flexen.app</a
              >
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">2. Hosting</h2>
            <p>
              This website is hosted by Vercel Inc. When you visit the website, information (e.g. IP address, time of
              access) is automatically stored in server log files. This data cannot be attributed to specific
              individuals. The legal basis is Art. 6(1)(f) GDPR (legitimate interest in stable website operation).
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">3. Analytics</h2>
            <p>
              We use Plausible Analytics — a privacy-friendly, cookie-free analytics tool. Plausible does not collect
              personal data, does not set cookies, and is fully GDPR compliant. Servers are located in the EU. More
              information: <a
                href="https://plausible.io/data-policy"
                target="_blank"
                rel="noopener"
                class="text-flexen-accent hover:underline">plausible.io/data-policy</a
              >.
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">4. Your Rights</h2>
            <p>You have the right to:</p>
            <ul class="mt-4 list-disc space-y-2 pl-6">
              <li>Access your stored data (Art. 15 GDPR)</li>
              <li>Rectification of inaccurate data (Art. 16 GDPR)</li>
              <li>Erasure of your data (Art. 17 GDPR)</li>
              <li>Restriction of processing (Art. 18 GDPR)</li>
              <li>Data portability (Art. 20 GDPR)</li>
              <li>Object to processing (Art. 21 GDPR)</li>
            </ul>
            <p class="mt-4">
              Contact us at: <a href="mailto:datenschutz@flexen.app" class="text-flexen-accent hover:underline"
                >datenschutz@flexen.app</a
              >
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">5. External Links</h2>
            <p>
              This website links to the Apple App Store and Google Play Store for downloading the Flexen App. The
              respective privacy policies of Apple and Google apply to data processing by these services.
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">6. Fonts</h2>
            <p>
              This website uses locally hosted fonts (self-hosting). No connections to external font servers (e.g.
              Google Fonts) are established.
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">7. Changes</h2>
            <p>
              We reserve the right to update this privacy policy. The current version is always available on this page.<br
              /><br />
              Last updated: March 2026
            </p>
          </div>

          <div class="gradient-card mt-12 rounded-2xl border border-white/5 p-6">
            <p class="mb-2 font-semibold text-white">Note</p>
            <p class="text-sm">
              This privacy policy is a draft and must be reviewed by a legal professional before launch.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
