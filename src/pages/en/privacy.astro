---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Home', url: 'https://flexen.app/en/' },
  { name: 'Privacy Policy', url: 'https://flexen.app/en/privacy' },
])
---

<BaseLayout
  title="Privacy Policy — Flexen"
  description="Privacy policy for the Flexen App website. Information about how we handle your data."
  locale="en"
  canonicalPath="/en/privacy"
  schema={breadcrumbSchema}
>
  <section class="section min-h-screen">
    <div class="container">
      <div class="content max-w-3xl">
        <h1 class="font-heading mb-12 text-h1 font-bold">Privacy Policy</h1>

        <div class="prose prose-invert text-secondary text-body space-y-8">
          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">1. Controller</h2>
            <p>
              The controller for data processing on this website is:<br /><br />
              <strong class="text-white">[Company Name]</strong><br />
              [Street + Number]<br />
              [Postal Code + City], Germany<br />
              Email: <a href="mailto:datenschutz@flexen.app" class="text-flexen-accent hover:underline"
                >datenschutz@flexen.app</a
              >
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">2. Hosting</h2>
            <p>
              This website is hosted by Vercel Inc. When you visit the website, information (e.g. IP address, time of
              access) is automatically stored in server log files. This data cannot be attributed to specific
              individuals. The legal basis is Art. 6(1)(f) GDPR (legitimate interest in stable website operation).
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">3. Analytics</h2>
            <p>
              We use Plausible Analytics — a privacy-friendly, cookie-free analytics tool. Plausible does not collect
              personal data, does not set cookies, and is fully GDPR compliant. Servers are located in the EU. More
              information: <a
                href="https://plausible.io/data-policy"
                target="_blank"
                rel="noopener"
                class="text-flexen-accent hover:underline">plausible.io/data-policy</a
              >.
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">4. Analytics in the Flexen App (PostHog)</h2>
            <p>
              With your explicit consent, we use <strong class="text-white">PostHog</strong> (PostHog Inc., 2261 Market
              Street #4008, San Francisco, CA 94114, USA) in the Flexen mobile app to analyse usage. All processing
              takes place exclusively on EU servers in Frankfurt, Germany — your data never leaves the European Union.
            </p>
            <p class="mt-4">
              <strong class="text-white">Legal basis:</strong> Art. 6(1)(a) GDPR (consent). You can withdraw your consent
              at any time in the app's settings under &ldquo;Anonymous usage statistics&rdquo;. This feature is <strong
                class="text-white">disabled by default</strong
              > on first use (opt-in).
            </p>
            <p class="mt-4">
              <strong class="text-white">Purpose:</strong> Improving the app, detecting errors, understanding which features
              are used, measuring user retention.
            </p>
            <p class="mt-4"><strong class="text-white">Data processed:</strong></p>
            <ul class="mt-2 list-disc space-y-2 pl-6">
              <li>
                Event metadata (e.g. &ldquo;meal logged&rdquo;, &ldquo;workout completed&rdquo;), <strong
                  class="text-white">without</strong
                > meal or workout content
              </li>
              <li>Screen views and tab switches</li>
              <li>Device and operating system information (model, OS version, language)</li>
              <li>
                Session replays: recordings of your screen interactions, with <strong class="text-white"
                  >all text and images automatically masked</strong
                >
              </li>
              <li>A pseudonymous user ID (Firebase UID) to associate events</li>
            </ul>
            <p class="mt-4">
              <strong class="text-white">What we explicitly do NOT collect:</strong> the contents of your meals, chat messages
              with Julio, weight values, steps, sleep data or any other health parameters.
            </p>
            <p class="mt-4">
              <strong class="text-white">Retention:</strong> Event data for a maximum of 12 months, session replays for 30
              days.
            </p>
            <p class="mt-4">
              <strong class="text-white">Data processing agreement:</strong> We have a Data Processing Agreement (DPA) with
              PostHog pursuant to Art. 28 GDPR. PostHog privacy policy: <a
                href="https://posthog.com/privacy"
                target="_blank"
                rel="noopener"
                class="text-flexen-accent hover:underline">posthog.com/privacy</a
              >.
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">5. Your Rights</h2>
            <p>You have the right to:</p>
            <ul class="mt-4 list-disc space-y-2 pl-6">
              <li>Access your stored data (Art. 15 GDPR)</li>
              <li>Rectification of inaccurate data (Art. 16 GDPR)</li>
              <li>Erasure of your data (Art. 17 GDPR)</li>
              <li>Restriction of processing (Art. 18 GDPR)</li>
              <li>Data portability (Art. 20 GDPR)</li>
              <li>Object to processing (Art. 21 GDPR)</li>
            </ul>
            <p class="mt-4">
              Contact us at: <a href="mailto:datenschutz@flexen.app" class="text-flexen-accent hover:underline"
                >datenschutz@flexen.app</a
              >
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">6. External Links</h2>
            <p>
              This website links to the Apple App Store and Google Play Store for downloading the Flexen App. The
              respective privacy policies of Apple and Google apply to data processing by these services.
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">7. Fonts</h2>
            <p>
              This website uses locally hosted fonts (self-hosting). No connections to external font servers (e.g.
              Google Fonts) are established.
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">8. Changes</h2>
            <p>
              We reserve the right to update this privacy policy. The current version is always available on this page.<br
              /><br />
              Last updated: March 2026
            </p>
          </div>

          <div class="gradient-card mt-12 rounded-2xl border border-border p-6">
            <p class="mb-2 font-semibold text-white">Note</p>
            <p class="text-sm">
              This privacy policy is a draft and must be reviewed by a legal professional before launch.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
