---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import en from '../../../i18n/en.json'
---

<BaseLayout
  title="Blog — Flexen"
  description="Tips on fitness, nutrition, sleep and AI. The Flexen Blog."
  locale="en"
  canonicalPath="/en/blog"
>
  <section class="section">
    <div class="container">
      <div class="content">
        <h1 class="text-[length:var(--text-h1)] font-bold mb-4 font-heading reveal">Blog</h1>
        <p class="text-secondary text-[length:var(--text-body)] mb-16 reveal">
          Tips, guides and insights on fitness, nutrition and AI.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="p-8 rounded-2xl gradient-card border border-white/5 text-center col-span-full">
            <p class="text-tertiary text-[length:var(--text-body)]">
              Our first articles are coming soon. Stay tuned!
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
