---
import BaseLayout from '../../layouts/BaseLayout.astro'
import en from '../../i18n/en.json'
---

<BaseLayout title="Features — Flexen" description="Discover Flexen's AI coach Julio, automatic food recognition, personalized workout plans and sleep tracking." locale="en" canonicalPath="/en/features">

  <!-- Hero Section -->
  <section class="section gradient-hero min-h-[70vh] flex items-center pt-32">
    <div class="container">
      <div class="content text-center">
        <h1 class="text-[length:var(--text-hero)] font-bold mb-6 reveal">
          {en.features.sectionTitle}
        </h1>
        <p class="text-secondary text-[length:var(--text-body)] mx-auto mb-8 max-w-2xl reveal">
          {en.features.sectionSubtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center reveal">
          <a
            href="#julio"
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl border border-white/10 text-white/80 font-medium hover:bg-white/5 transition-colors"
          >
            Explore features
          </a>
          <a
            href="#"
            class="btn-glow inline-flex items-center justify-center px-8 py-4 rounded-xl gradient-accent text-white font-semibold text-lg transition-transform hover:scale-[1.02] active:scale-[0.97]"
          >
            {en.hero.cta}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Julio -->
  <section class="section" id="julio">
    <div class="container">
      <div class="content">
        <div class="flex flex-col md:flex-row gap-16 items-center">
          <div class="flex-1 reveal">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-medium gradient-accent text-white mb-4">{en.features.julio.badge}</span>
            <h2 class="text-[length:var(--text-h2)] font-bold mb-4">{en.features.julio.title}</h2>
            <p class="text-secondary text-[length:var(--text-body)] mb-8">{en.features.julio.description}</p>
            <ul class="space-y-4 stagger-children">
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Real-time workout plans</span>
                  <p class="text-[length:var(--text-small)] mt-1">Tell Julio your goal — he builds your plan in seconds. Adapted to your level and equipment.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Nutrition advice using your data</span>
                  <p class="text-[length:var(--text-small)] mt-1">Julio knows your calorie target, preferences and allergies. He suggests what you should eat.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Sleep tips based on your patterns</span>
                  <p class="text-[length:var(--text-small)] mt-1">He analyzes your sleep history and gives you concrete tips for better recovery.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Natural language</span>
                  <p class="text-[length:var(--text-small)] mt-1">No menu clicking. Just type what you want — Julio understands you.</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="flex-1 flex justify-center reveal">
            <div class="w-full max-w-[300px] aspect-[9/16] rounded-[2.5rem] bg-flexen-dark-mid border border-white/5 shadow-2xl shadow-flexen-accent/5"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Food AI -->
  <section class="section" id="food-ai">
    <div class="container">
      <div class="content">
        <div class="flex flex-col md:flex-row-reverse gap-16 items-center">
          <div class="flex-1 reveal">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-success/20 text-success mb-4">{en.features.foodAI.badge}</span>
            <h2 class="text-[length:var(--text-h2)] font-bold mb-4">{en.features.foodAI.title}</h2>
            <p class="text-secondary text-[length:var(--text-body)] mb-8">{en.features.foodAI.description}</p>
            <ul class="space-y-4 stagger-children">
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Over 10,000 foods</span>
                  <p class="text-[length:var(--text-small)] mt-1">Our AI recognizes dishes, individual ingredients and even composed plates with approx. 90% accuracy.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Barcode scanner</span>
                  <p class="text-[length:var(--text-small)] mt-1">Just scan packaged products — nutritional values are loaded automatically from our database.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Learns from your corrections</span>
                  <p class="text-[length:var(--text-small)] mt-1">Correct a result and the AI remembers. The more you use it, the more accurate it gets.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Automatic macro calculation</span>
                  <p class="text-[length:var(--text-small)] mt-1">Calories, protein, carbs, fat — everything is calculated instantly and added to your daily log.</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="flex-1 flex justify-center reveal">
            <div class="w-full max-w-[300px] aspect-[9/16] rounded-[2.5rem] bg-flexen-dark-mid border border-white/5 shadow-2xl shadow-success/5"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Training -->
  <section class="section" id="training">
    <div class="container">
      <div class="content">
        <div class="flex flex-col md:flex-row gap-16 items-center">
          <div class="flex-1 reveal">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-flexen-accent/20 text-flexen-accent mb-4">{en.features.training.badge}</span>
            <h2 class="text-[length:var(--text-h2)] font-bold mb-4">{en.features.training.title}</h2>
            <p class="text-secondary text-[length:var(--text-body)] mb-8">{en.features.training.description}</p>
            <ul class="space-y-4 stagger-children">
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Automatic progressive overload</span>
                  <p class="text-[length:var(--text-small)] mt-1">Julio increases weight and volume based on your progress — no manual calculations needed.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Built-in timer</span>
                  <p class="text-[length:var(--text-small)] mt-1">Set timers and rest periods run automatically. Vibration when the next exercise is up.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Exercise guides with videos</span>
                  <p class="text-[length:var(--text-small)] mt-1">Every exercise is explained — with proper form and common mistakes.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Flexible with equipment</span>
                  <p class="text-[length:var(--text-small)] mt-1">Gym, home gym or bodyweight — Julio adapts the plan to whatever you have available.</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="flex-1 flex justify-center reveal">
            <div class="w-full max-w-[300px] aspect-[9/16] rounded-[2.5rem] bg-flexen-dark-mid border border-white/5 shadow-2xl shadow-flexen-accent/5"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Sleep -->
  <section class="section" id="sleep">
    <div class="container">
      <div class="content">
        <div class="flex flex-col md:flex-row-reverse gap-16 items-center">
          <div class="flex-1 reveal">
            <h2 class="text-[length:var(--text-h2)] font-bold mb-4">{en.features.sleep.title}</h2>
            <p class="text-secondary text-[length:var(--text-body)] mb-8">{en.features.sleep.description}</p>
            <ul class="space-y-4 stagger-children">
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Automatic tracking</span>
                  <p class="text-[length:var(--text-small)] mt-1">Via Health Connect and HealthKit — no wearable needed, but compatible with all major devices.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Sleep phase analysis</span>
                  <p class="text-[length:var(--text-small)] mt-1">See exactly how much deep sleep and REM sleep you get — and what it means for your recovery.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Spot patterns</span>
                  <p class="text-[length:var(--text-small)] mt-1">Flexen shows you trends over weeks and months — discover what improves or hurts your sleep.</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="flex-1 flex justify-center reveal">
            <div class="w-full max-w-[300px] aspect-[9/16] rounded-[2.5rem] bg-flexen-dark-mid border border-white/5 shadow-2xl shadow-purple-500/5"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Journal -->
  <section class="section" id="journal">
    <div class="container">
      <div class="content">
        <div class="flex flex-col md:flex-row gap-16 items-center">
          <div class="flex-1 reveal">
            <h2 class="text-[length:var(--text-h2)] font-bold mb-4">{en.features.journal.title}</h2>
            <p class="text-secondary text-[length:var(--text-body)] mb-8">{en.features.journal.description}</p>
            <ul class="space-y-4 stagger-children">
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Voice input</span>
                  <p class="text-[length:var(--text-small)] mt-1">Just talk — Flexen converts your words to text. Journaling without typing.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Mood tracking</span>
                  <p class="text-[length:var(--text-small)] mt-1">Log your mood with a single tap. See over weeks how training and nutrition affect your wellbeing.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Daily writing prompts</span>
                  <p class="text-[length:var(--text-small)] mt-1">Not sure what to write? Flexen gives you a fresh prompt every day for reflection and mindfulness.</p>
                </div>
              </li>
              <li class="flex items-start gap-3 text-secondary">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="text-white font-medium">Everything connected</span>
                  <p class="text-[length:var(--text-small)] mt-1">Your journal is linked to training, sleep and nutrition. Julio spots connections you wouldn't see on your own.</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="flex-1 flex justify-center reveal">
            <div class="w-full max-w-[300px] aspect-[9/16] rounded-[2.5rem] bg-flexen-dark-mid border border-white/5 shadow-2xl shadow-amber-500/5"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- All Features Overview -->
  <section class="section">
    <div class="container">
      <div class="content">
        <h2 class="text-[length:var(--text-h2)] font-bold text-center mb-4 reveal">Everything at a glance</h2>
        <p class="text-secondary text-[length:var(--text-body)] text-center mb-16 reveal">What's included in Free and Premium.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
          <div class="p-6 rounded-2xl gradient-card border border-white/5 card-hover gradient-border">
            <div class="w-10 h-10 rounded-xl gradient-accent flex items-center justify-center mb-4 text-white font-bold">J</div>
            <h3 class="font-semibold text-lg mb-2">AI Coach Julio</h3>
            <p class="text-secondary text-[length:var(--text-small)]">Unlimited queries with Premium. 3 per day in Free.</p>
          </div>
          <div class="p-6 rounded-2xl gradient-card border border-white/5 card-hover gradient-border">
            <div class="w-10 h-10 rounded-xl bg-success/20 flex items-center justify-center mb-4 text-success font-bold">F</div>
            <h3 class="font-semibold text-lg mb-2">Photo food recognition</h3>
            <p class="text-secondary text-[length:var(--text-small)]">AI-powered in Premium. Manual logging in Free.</p>
          </div>
          <div class="p-6 rounded-2xl gradient-card border border-white/5 card-hover gradient-border">
            <div class="w-10 h-10 rounded-xl bg-flexen-accent/20 flex items-center justify-center mb-4 text-flexen-accent font-bold">T</div>
            <h3 class="font-semibold text-lg mb-2">Workout plans</h3>
            <p class="text-secondary text-[length:var(--text-small)]">Unlimited plans in Premium. 1 active plan in Free.</p>
          </div>
          <div class="p-6 rounded-2xl gradient-card border border-white/5 card-hover gradient-border">
            <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center mb-4 text-purple-400 font-bold">S</div>
            <h3 class="font-semibold text-lg mb-2">Sleep tracking</h3>
            <p class="text-secondary text-[length:var(--text-small)]">Advanced analytics in Premium. Basic tracking in Free.</p>
          </div>
          <div class="p-6 rounded-2xl gradient-card border border-white/5 card-hover gradient-border">
            <div class="w-10 h-10 rounded-xl bg-amber-500/20 flex items-center justify-center mb-4 text-amber-400 font-bold">M</div>
            <h3 class="font-semibold text-lg mb-2">Journal & mental health</h3>
            <p class="text-secondary text-[length:var(--text-small)]">Voice journal and prompts in Premium. Basic journal in Free.</p>
          </div>
          <div class="p-6 rounded-2xl gradient-card border border-white/5 card-hover gradient-border">
            <div class="w-10 h-10 rounded-xl bg-rose-500/20 flex items-center justify-center mb-4 text-rose-400 font-bold">+</div>
            <h3 class="font-semibold text-lg mb-2">Ad-free</h3>
            <p class="text-secondary text-[length:var(--text-small)]">Premium is completely ad-free. Your data is never sold.</p>
          </div>
        </div>
        <div class="text-center mt-12 reveal">
          <a
            href="/en/#pricing"
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl border border-white/10 text-white/80 font-medium hover:bg-white/5 transition-colors"
          >
            Compare plans
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section gradient-hero">
    <div class="container">
      <div class="content text-center">
        <h2 class="text-[length:var(--text-h1)] font-bold mb-6 reveal">{en.finalCta.headline}</h2>
        <p class="text-secondary text-[length:var(--text-body)] mx-auto mb-8 reveal">{en.finalCta.subline}</p>
        <a href="#" class="btn-glow inline-flex items-center justify-center px-10 py-4 rounded-xl gradient-accent text-white font-semibold text-lg transition-transform hover:scale-[1.02] active:scale-[0.97] reveal">{en.finalCta.cta}</a>
      </div>
    </div>
  </section>

</BaseLayout>
