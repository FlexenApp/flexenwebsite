---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'
import en from '../../i18n/en.json'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Home', url: 'https://flexen.app/en/' },
  { name: 'Features', url: 'https://flexen.app/en/features' },
])
---

<BaseLayout
  title="Features — Flexen"
  description="Discover Flexen's AI coach Julio, automatic food recognition, personalized workout plans and sleep tracking."
  locale="en"
  canonicalPath="/en/features"
  schema={breadcrumbSchema}
>
  <!-- Hero Section -->
  <section class="section gradient-hero flex min-h-[70vh] items-center pt-32">
    <div class="container">
      <div class="content text-center">
        <h1 class="reveal mb-6 text-hero font-bold">
          {en.features.sectionTitle}
        </h1>
        <p class="text-secondary reveal text-body mx-auto mb-8 max-w-2xl">
          {en.features.sectionSubtitle}
        </p>
        <div class="reveal flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="#julio"
            class="inline-flex items-center justify-center rounded-xl border border-white/10 px-8 py-4 font-medium text-white/80 transition-colors hover:bg-white/5"
          >
            Explore features
          </a>
          <a
            href="#"
            class="btn-glow gradient-accent inline-flex items-center justify-center rounded-xl px-8 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
          >
            {en.hero.cta}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Julio -->
  <section class="section" id="julio">
    <div class="container">
      <div class="content">
        <div class="flex flex-col items-center gap-16 md:flex-row">
          <div class="reveal flex-1">
            <span class="gradient-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium text-white"
              >{en.features.julio.badge}</span
            >
            <h2 class="mb-4 text-h2 font-bold">{en.features.julio.title}</h2>
            <p class="text-secondary text-body mb-8">{en.features.julio.description}</p>
            <ul class="stagger-children space-y-4">
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Real-time workout plans</span>
                  <p class="mt-1 text-small">
                    Tell Julio your goal — he builds your plan in seconds. Adapted to your level and equipment.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Nutrition advice using your data</span>
                  <p class="mt-1 text-small">
                    Julio knows your calorie target, preferences and allergies. He suggests what you should eat.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Sleep tips based on your patterns</span>
                  <p class="mt-1 text-small">
                    He analyzes your sleep history and gives you concrete tips for better recovery.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Natural language</span>
                  <p class="mt-1 text-small">
                    No menu clicking. Just type what you want — Julio understands you.
                  </p>
                </div>
              </li>
            </ul>
          </div>
          <div class="reveal flex flex-1 justify-center">
            <div
              class="bg-flexen-dark-mid shadow-flexen-accent/5 aspect-[9/16] w-full max-w-[300px] rounded-[2.5rem] border border-white/5 shadow-2xl"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Food AI -->
  <section class="section" id="food-ai">
    <div class="container">
      <div class="content">
        <div class="flex flex-col items-center gap-16 md:flex-row-reverse">
          <div class="reveal flex-1">
            <span class="bg-success/20 text-success mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >{en.features.foodAI.badge}</span
            >
            <h2 class="mb-4 text-h2 font-bold">{en.features.foodAI.title}</h2>
            <p class="text-secondary text-body mb-8">{en.features.foodAI.description}</p>
            <ul class="stagger-children space-y-4">
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Over 10,000 foods</span>
                  <p class="mt-1 text-small">
                    Our AI recognizes dishes, individual ingredients and even composed plates with approx. 90% accuracy.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Barcode scanner</span>
                  <p class="mt-1 text-small">
                    Just scan packaged products — nutritional values are loaded automatically from our database.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Learns from your corrections</span>
                  <p class="mt-1 text-small">
                    Correct a result and the AI remembers. The more you use it, the more accurate it gets.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Automatic macro calculation</span>
                  <p class="mt-1 text-small">
                    Calories, protein, carbs, fat — everything is calculated instantly and added to your daily log.
                  </p>
                </div>
              </li>
            </ul>
          </div>
          <div class="reveal flex flex-1 justify-center">
            <div
              class="bg-flexen-dark-mid shadow-success/5 aspect-[9/16] w-full max-w-[300px] rounded-[2.5rem] border border-white/5 shadow-2xl"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Training -->
  <section class="section" id="training">
    <div class="container">
      <div class="content">
        <div class="flex flex-col items-center gap-16 md:flex-row">
          <div class="reveal flex-1">
            <span
              class="bg-flexen-accent/20 text-flexen-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >{en.features.training.badge}</span
            >
            <h2 class="mb-4 text-h2 font-bold">{en.features.training.title}</h2>
            <p class="text-secondary text-body mb-8">{en.features.training.description}</p>
            <ul class="stagger-children space-y-4">
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Automatic progressive overload</span>
                  <p class="mt-1 text-small">
                    Julio increases weight and volume based on your progress — no manual calculations needed.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Built-in timer</span>
                  <p class="mt-1 text-small">
                    Set timers and rest periods run automatically. Vibration when the next exercise is up.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Exercise guides with videos</span>
                  <p class="mt-1 text-small">
                    Every exercise is explained — with proper form and common mistakes.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Flexible with equipment</span>
                  <p class="mt-1 text-small">
                    Gym, home gym or bodyweight — Julio adapts the plan to whatever you have available.
                  </p>
                </div>
              </li>
            </ul>
          </div>
          <div class="reveal flex flex-1 justify-center">
            <div
              class="bg-flexen-dark-mid shadow-flexen-accent/5 aspect-[9/16] w-full max-w-[300px] rounded-[2.5rem] border border-white/5 shadow-2xl"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Sleep -->
  <section class="section" id="sleep">
    <div class="container">
      <div class="content">
        <div class="flex flex-col items-center gap-16 md:flex-row-reverse">
          <div class="reveal flex-1">
            <h2 class="mb-4 text-h2 font-bold">{en.features.sleep.title}</h2>
            <p class="text-secondary text-body mb-8">{en.features.sleep.description}</p>
            <ul class="stagger-children space-y-4">
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Automatic tracking</span>
                  <p class="mt-1 text-small">
                    Via Health Connect and HealthKit — no wearable needed, but compatible with all major devices.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Sleep phase analysis</span>
                  <p class="mt-1 text-small">
                    See exactly how much deep sleep and REM sleep you get — and what it means for your recovery.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Spot patterns</span>
                  <p class="mt-1 text-small">
                    Flexen shows you trends over weeks and months — discover what improves or hurts your sleep.
                  </p>
                </div>
              </li>
            </ul>
          </div>
          <div class="reveal flex flex-1 justify-center">
            <div
              class="bg-flexen-dark-mid aspect-[9/16] w-full max-w-[300px] rounded-[2.5rem] border border-white/5 shadow-2xl shadow-purple-500/5"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Journal -->
  <section class="section" id="journal">
    <div class="container">
      <div class="content">
        <div class="flex flex-col items-center gap-16 md:flex-row">
          <div class="reveal flex-1">
            <h2 class="mb-4 text-h2 font-bold">{en.features.journal.title}</h2>
            <p class="text-secondary text-body mb-8">{en.features.journal.description}</p>
            <ul class="stagger-children space-y-4">
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Voice input</span>
                  <p class="mt-1 text-small">
                    Just talk — Flexen converts your words to text. Journaling without typing.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Mood tracking</span>
                  <p class="mt-1 text-small">
                    Log your mood with a single tap. See over weeks how training and nutrition affect your wellbeing.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Daily writing prompts</span>
                  <p class="mt-1 text-small">
                    Not sure what to write? Flexen gives you a fresh prompt every day for reflection and mindfulness.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Everything connected</span>
                  <p class="mt-1 text-small">
                    Your journal is linked to training, sleep and nutrition. Julio spots connections you wouldn't see on
                    your own.
                  </p>
                </div>
              </li>
            </ul>
          </div>
          <div class="reveal flex flex-1 justify-center">
            <div
              class="bg-flexen-dark-mid aspect-[9/16] w-full max-w-[300px] rounded-[2.5rem] border border-white/5 shadow-2xl shadow-amber-500/5"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- All Features Overview -->
  <section class="section">
    <div class="container">
      <div class="content">
        <h2 class="reveal mb-4 text-center text-h2 font-bold">Everything at a glance</h2>
        <p class="text-secondary reveal text-body mb-16 text-center">What's included in Free and Premium.</p>
        <div class="stagger-children grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-6">
            <div
              class="gradient-accent mb-4 flex h-10 w-10 items-center justify-center rounded-xl font-bold text-white"
            >
              J
            </div>
            <h3 class="mb-2 text-lg font-semibold">AI Coach Julio</h3>
            <p class="text-secondary text-small">
              Unlimited queries with Premium. 3 per day in Free.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-6">
            <div
              class="bg-success/20 text-success mb-4 flex h-10 w-10 items-center justify-center rounded-xl font-bold"
            >
              F
            </div>
            <h3 class="mb-2 text-lg font-semibold">Photo food recognition</h3>
            <p class="text-secondary text-small">AI-powered in Premium. Manual logging in Free.</p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-6">
            <div
              class="bg-flexen-accent/20 text-flexen-accent mb-4 flex h-10 w-10 items-center justify-center rounded-xl font-bold"
            >
              T
            </div>
            <h3 class="mb-2 text-lg font-semibold">Workout plans</h3>
            <p class="text-secondary text-small">
              Unlimited plans in Premium. 1 active plan in Free.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-6">
            <div
              class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-purple-500/20 font-bold text-purple-400"
            >
              S
            </div>
            <h3 class="mb-2 text-lg font-semibold">Sleep tracking</h3>
            <p class="text-secondary text-small">
              Advanced analytics in Premium. Basic tracking in Free.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-6">
            <div
              class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-500/20 font-bold text-amber-400"
            >
              M
            </div>
            <h3 class="mb-2 text-lg font-semibold">Journal & mental health</h3>
            <p class="text-secondary text-small">
              Voice journal and prompts in Premium. Basic journal in Free.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-6">
            <div
              class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-rose-500/20 font-bold text-rose-400"
            >
              +
            </div>
            <h3 class="mb-2 text-lg font-semibold">Ad-free</h3>
            <p class="text-secondary text-small">
              Premium is completely ad-free. Your data is never sold.
            </p>
          </div>
        </div>
        <div class="reveal mt-12 text-center">
          <a
            href="/en/#pricing"
            class="inline-flex items-center justify-center rounded-xl border border-white/10 px-8 py-4 font-medium text-white/80 transition-colors hover:bg-white/5"
          >
            Compare plans
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section gradient-hero">
    <div class="container">
      <div class="content text-center">
        <h2 class="reveal mb-6 text-h1 font-bold">{en.finalCta.headline}</h2>
        <p class="text-secondary reveal text-body mx-auto mb-8">{en.finalCta.subline}</p>
        <a
          href="#"
          class="btn-glow gradient-accent reveal inline-flex items-center justify-center rounded-xl px-10 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
          >{en.finalCta.cta}</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
