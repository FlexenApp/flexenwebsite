---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'
import en from '../../i18n/en.json'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Home', url: 'https://flexen.co/en/' },
  { name: 'About us', url: 'https://flexen.co/en/about' },
])
---

<BaseLayout
  title="About us — Flexen"
  description="The story behind Flexen: Why we're building an AI-powered health app that combines fitness, nutrition, sleep and mental health in one place."
  locale="en"
  canonicalPath="/en/about"
  schema={breadcrumbSchema}
>
  <!-- Hero Section -->
  <section class="section gradient-hero flex min-h-[70vh] items-center pt-32">
    <div class="container">
      <div class="content mx-auto max-w-3xl text-center">
        <span class="gradient-accent reveal mb-6 inline-block rounded-full px-4 py-1.5 text-xs font-medium text-white"
          >Our story</span
        >
        <h1 class="reveal mb-6 text-hero font-bold">The story behind Flexen</h1>
        <p class="text-secondary reveal text-body mx-auto mb-8">
          Flexen was born from a simple frustration: Why do you need 5 apps when one can do it all? Calorie counter
          here, workout planner there, sleep tracker over there — and none of them talk to each other. We wanted to
          change that.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="section" id="mission">
    <div class="container">
      <div class="content mx-auto max-w-4xl">
        <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
          <div>
            <h2 class="reveal mb-6 text-h2 font-bold">Holistic health, accessible to everyone</h2>
            <p class="text-secondary reveal text-body mb-4">
              Our vision: combine AI with health data so that everyone has access to a personal coach — not just those
              who can afford a trainer.
            </p>
            <p class="text-secondary reveal text-body">
              Living a holistically healthy life shouldn't require five different subscriptions. Flexen brings together
              nutrition, training, sleep, mental health and AI coaching in a single app. Personal. Intelligent.
              Affordable.
            </p>
          </div>
          <div class="gradient-card reveal rounded-2xl border border-border p-8">
            <blockquote class="text-secondary text-body italic">
              &ldquo;Health is not a luxury. Everyone deserves a coach who knows their data, understands their goals,
              and is available around the clock.&rdquo;
            </blockquote>
            <p class="text-flexen-accent mt-4 text-small font-semibold">— The Flexen Team</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What makes Flexen different -->
  <section class="section" id="difference">
    <div class="container">
      <div class="content">
        <h2 class="reveal mb-4 text-center text-h2 font-bold">What makes Flexen different</h2>
        <p class="text-secondary reveal text-body mx-auto mb-16 max-w-2xl text-center">
          Three principles that guide everything we build.
        </p>
        <div class="stagger-children grid grid-cols-1 gap-6 md:grid-cols-3">
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-8">
            <span class="gradient-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium text-white"
              >AI-Powered</span
            >
            <h3 class="mb-3 text-h3 font-bold">AI as a coach, not a gimmick</h3>
            <p class="text-secondary text-body">
              Julio isn't a marketing feature. He has access to your data and can take real action: create plans,
              analyze progress, make recommendations. A real coach that keeps learning.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-8">
            <span class="bg-success/20 text-success mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >Holistic</span
            >
            <h3 class="mb-3 text-h3 font-bold">Holistic, not fragmented</h3>
            <p class="text-secondary text-body">
              Nutrition affects sleep. Sleep affects training. Training affects mood. Flexen understands these
              connections — because all your data lives in one place.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-8">
            <span
              class="bg-flexen-accent/20 text-flexen-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >Privacy</span
            >
            <h3 class="mb-3 text-h3 font-bold">Your data belongs to you</h3>
            <p class="text-secondary text-body">
              Health data is the most personal data there is. We don't sell it, we don't share it, and we never will.
              Your data stays your data. Period.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech/AI Section -->
  <section class="section" id="technology">
    <div class="container">
      <div class="content mx-auto max-w-4xl">
        <h2 class="reveal mb-4 text-center text-h2 font-bold">The technology behind Flexen</h2>
        <p class="text-secondary reveal text-body mx-auto mb-16 max-w-2xl text-center">
          Cutting-edge AI, seamlessly integrated into your daily life.
        </p>
        <div class="stagger-children space-y-6">
          <div
            class="gradient-card card-hover flex flex-col items-start gap-6 rounded-2xl border border-border p-8 md:flex-row"
          >
            <div class="gradient-accent flex h-12 w-12 shrink-0 items-center justify-center rounded-xl">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
                ></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="mb-2 text-h3 font-bold">Computer vision for food recognition</h3>
              <p class="text-secondary text-body">
                Flexen's AI analyzes photos of your meals in real time. Over 10,000 foods are recognized — with
                calories, macros and portion sizes. No manual entry, no guessing.
              </p>
            </div>
          </div>
          <div
            class="gradient-card card-hover flex flex-col items-start gap-6 rounded-2xl border border-border p-8 md:flex-row"
          >
            <div class="gradient-accent flex h-12 w-12 shrink-0 items-center justify-center rounded-xl">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="mb-2 text-h3 font-bold">LLM with function calling for Julio</h3>
              <p class="text-secondary text-body">
                Julio is more than a chatbot. Through function calling, he can actively access your data and take
                action: create workout plans, analyze meals, detect sleep patterns — all through natural language.
              </p>
            </div>
          </div>
          <div
            class="gradient-card card-hover flex flex-col items-start gap-6 rounded-2xl border border-border p-8 md:flex-row"
          >
            <div class="gradient-accent flex h-12 w-12 shrink-0 items-center justify-center rounded-xl">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="mb-2 text-h3 font-bold">Health Connect & HealthKit integration</h3>
              <p class="text-secondary text-body">
                Flexen connects seamlessly with your smartphone's health ecosystem. Sleep, steps, heart rate —
                everything flows together automatically. No additional wearable needed.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section gradient-hero">
    <div class="container">
      <div class="content text-center">
        <h2 class="reveal mb-6 text-h1 font-bold">{en.finalCta.headline}</h2>
        <p class="text-secondary reveal text-body mx-auto mb-8">{en.finalCta.subline}</p>
        <a
          href="#"
          class="btn-glow gradient-accent reveal inline-flex items-center justify-center rounded-xl px-10 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
          >{en.finalCta.cta}</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
