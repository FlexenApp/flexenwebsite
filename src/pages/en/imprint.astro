---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Home', url: 'https://flexen.app/en/' },
  { name: 'Imprint', url: 'https://flexen.app/en/imprint' },
])
---

<BaseLayout
  title="Imprint — Flexen"
  description="Legal imprint and provider identification for Flexen App."
  locale="en"
  canonicalPath="/en/imprint"
  schema={breadcrumbSchema}
>
  <section class="section min-h-screen">
    <div class="container">
      <div class="content max-w-3xl">
        <h1 class="font-heading mb-12 text-h1 font-bold">Imprint</h1>

        <div class="prose prose-invert text-secondary text-body space-y-8">
          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">
              Information according to &sect; 5 DDG
            </h2>
            <p>
              <strong class="text-white">[Company Name]</strong><br />
              [Street + Number]<br />
              [Postal Code + City]<br />
              Germany
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">Contact</h2>
            <p>
              Email: <a href="mailto:kontakt@flexen.app" class="text-flexen-accent hover:underline"
                >kontakt@flexen.app</a
              ><br />
              Phone: [+49 XXX XXXXXXX]
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">Commercial Register</h2>
            <p>
              Register Court: [Local Court]<br />
              Register Number: [HRB XXXXX]<br />
              Managing Director: [Name]
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">VAT ID</h2>
            <p>
              VAT identification number according to &sect; 27a UStG:<br />
              DE XXXXXXXXX
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">Dispute Resolution</h2>
            <p>
              The European Commission provides a platform for online dispute resolution (ODR):
              <a
                href="https://ec.europa.eu/consumers/odr/"
                target="_blank"
                rel="noopener"
                class="text-flexen-accent hover:underline">https://ec.europa.eu/consumers/odr/</a
              >.
            </p>
            <p>
              We are not willing or obliged to participate in dispute resolution proceedings before a consumer
              arbitration board.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
