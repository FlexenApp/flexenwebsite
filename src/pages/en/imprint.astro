---
import MinimalLegalLayout from '../../layouts/MinimalLegalLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Home', url: 'https://flexen.co/en/' },
  { name: 'Imprint', url: 'https://flexen.co/en/imprint' },
])
---

<MinimalLegalLayout
  title="Imprint — Flexen UG"
  description="Legal imprint and provider identification for Flexen UG (haftungsbeschränkt)."
  locale="en"
  canonicalPath="/en/imprint"
  schema={breadcrumbSchema}
>
  <section class="section min-h-screen">
    <div class="container">
      <div class="content max-w-3xl">
        <h1 class="font-heading text-h1 mb-4 font-bold">Imprint</h1>
        <p class="text-secondary text-body mb-12">
          This imprint applies to <strong class="text-white">flexen.co</strong> and to all products of Flexen UG (haftungsbeschr&auml;nkt)
          — currently
          <strong class="text-white">Flexen</strong> and
          <strong class="text-white">Project Pluto</strong>.
        </p>

        <div class="prose prose-invert text-secondary text-body space-y-8">
          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">Information according to &sect; 5 DDG</h2>
            <p>
              <strong class="text-white">Flexen UG (haftungsbeschr&auml;nkt)</strong><br />
              Paul-Heidelbach-Stra&szlig;e 14<br />
              34134 Kassel<br />
              Germany
            </p>
          </div>

          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">Contact</h2>
            <p>
              Email: <a href="mailto:info@flexen.co" class="text-flexen-accent hover:underline">info@flexen.co</a>
            </p>
          </div>

          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">Commercial Register</h2>
            <p>
              Register Court: Amtsgericht Kassel (Local Court Kassel)<br />
              Register Number: HRB 20498<br />
              Managing Directors: Leonard Hoppe, Marcel Schneider, Leon Schmelzle
            </p>
          </div>

          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">VAT ID</h2>
            <p>
              VAT identification number according to &sect; 27a UStG:<br />
              DE459052032
            </p>
          </div>

          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">Responsible for content</h2>
            <p>
              pursuant to &sect; 18 (2) MStV:<br />
              Leonard Hoppe<br />
              Paul-Heidelbach-Stra&szlig;e 14, 34134 Kassel
            </p>
          </div>

          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">Dispute Resolution</h2>
            <p>
              We are not willing or obliged to participate in dispute resolution proceedings before a consumer
              arbitration board.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</MinimalLegalLayout>
