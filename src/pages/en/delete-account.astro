---
import MinimalLegalLayout from '../../layouts/MinimalLegalLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Home', url: 'https://flexen.co/en/' },
  { name: 'Delete account', url: 'https://flexen.co/en/delete-account' },
])
---

<MinimalLegalLayout
  title="Delete account — Flexen"
  description="How to delete your Flexen account and all associated data — directly in the app or by email."
  locale="en"
  canonicalPath="/en/delete-account"
  schema={breadcrumbSchema}
>
  <section class="section min-h-screen">
    <div class="container">
      <div class="content max-w-3xl">
        <h1 class="font-heading text-h1 mb-4 font-bold">Delete account</h1>
        <p class="text-secondary text-body mb-12">
          You can delete your <strong class="text-white">Flexen</strong> account at any time — directly in the app or by email.
          Your data is deleted or anonymised in our active systems unless statutory retention obligations require longer storage.
        </p>

        <div class="prose prose-invert text-secondary text-body space-y-8">
          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">How to delete your account in the app</h2>
            <ol class="mt-4 list-decimal space-y-2 pl-6">
              <li>Open the Flexen app and sign in.</li>
              <li>
                Go to <strong class="text-white">Settings &rarr; Account</strong>.
              </li>
              <li>
                Tap <strong class="text-white">&ldquo;Delete account&rdquo;</strong>.
              </li>
              <li>Confirm the deletion in the confirmation dialog.</li>
            </ol>
            <p class="mt-4">The deletion is started immediately and cannot be undone.</p>
          </div>

          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">What gets deleted</h2>
            <p>Together with your account, we delete all associated data:</p>
            <ul class="mt-4 list-disc space-y-2 pl-6">
              <li>
                <strong class="text-white">Profile:</strong> email, username, display name, body data (height, weight, body
                fat), goals, and preferences
              </li>
              <li>
                <strong class="text-white">Health data:</strong> steps and sleep data
              </li>
              <li>
                <strong class="text-white">Nutrition data:</strong> meal logs, recipes, and fridge inventory
              </li>
              <li>
                <strong class="text-white">Photos:</strong> all uploaded meal and recipe photos
              </li>
              <li>
                <strong class="text-white">Medication data:</strong> name, dosage, schedule, and intake history
              </li>
              <li>
                <strong class="text-white">Journal:</strong> journal entries and mood data
              </li>
              <li>
                <strong class="text-white">Training:</strong> training plans, exercises, weight history, and water tracking
              </li>
              <li><strong class="text-white">AI chats:</strong> all chat histories</li>
              <li>
                <strong class="text-white">Friends data:</strong> friendships and activity snapshots — on both sides
              </li>
              <li>
                <strong class="text-white">Login:</strong> your user account including sign-in credentials
              </li>
            </ul>
          </div>

          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">Retention and Backups</h2>
            <p>
              We may retain consent records, security logs, and purchase-related records where this is required to meet
              legal obligations or defend legal claims. Backups are overwritten within 30 days at the latest.
            </p>
          </div>

          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">Deletion without app access</h2>
            <p>
              No longer have access to the app? Send us an email at
              <a href="mailto:info@flexen.co" class="text-flexen-accent hover:underline">info@flexen.co</a> — from the email
              address your account is registered with. We process your request within <strong class="text-white"
                >30 days at most</strong
              >.
            </p>
          </div>

          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">
              Important: cancel your subscription separately
            </h2>
            <p>
              Deleting your account does <strong class="text-white">NOT cancel your subscription</strong>. Subscriptions
              are handled entirely by Apple and Google — cancel an active subscription separately in your
              <strong class="text-white">App&nbsp;Store</strong> account settings (iOS) or in the <strong
                class="text-white">Google&nbsp;Play&nbsp;Store</strong
              > (Android), ideally <em>before</em> deleting your account.
            </p>
          </div>

          <div>
            <h2 class="font-heading text-h3 mb-4 font-bold text-white">Questions?</h2>
            <p>
              You can find more about how we process your data in our
              <a href="/en/privacy" class="text-flexen-accent hover:underline">Privacy Policy</a>. If you have
              questions, our
              <a href="/en/support" class="text-flexen-accent hover:underline">Support</a> is happy to help.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</MinimalLegalLayout>
