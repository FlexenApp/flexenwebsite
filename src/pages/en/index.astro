---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getAppSchema, getFAQSchema } from '../../lib/seo'
import en from '../../i18n/en.json'
import NewsletterSignup from '../../components/astro/NewsletterSignup.astro'
import AppStoreBadges from '../../components/astro/AppStoreBadges.astro'

const schema = getAppSchema()
const faqSchema = getFAQSchema(en.faq.items)
---

<BaseLayout
  title={en.meta.title}
  description={en.meta.description}
  locale="en"
  canonicalPath="/en/"
  schema={[schema, faqSchema]}
>
  <section class="section gradient-hero flex min-h-screen items-center">
    <div class="container">
      <div class="content text-center">
        <h1 class="mb-6 text-[length:var(--text-hero)] font-bold" data-hero-headline style="opacity:0;">
          {en.hero.headline}
        </h1>
        <p class="text-secondary text-body mx-auto mb-8" data-hero-subline>{en.hero.subline}</p>
        <div class="mb-6 flex flex-col items-center justify-center gap-4 sm:flex-row" data-hero-ctas>
          <a
            href="#"
            class="btn-glow gradient-accent inline-flex items-center justify-center rounded-xl px-8 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
            data-magnetic>{en.hero.cta}</a
          >
          <a
            href="/en/features"
            class="inline-flex items-center justify-center rounded-xl border border-white/10 px-8 py-4 font-medium text-white/80 transition-colors hover:bg-white/5"
            >{en.hero.ctaSecondary}</a
          >
        </div>
        <p class="text-tertiary reveal text-[length:var(--text-small)]">{en.hero.microcopy}</p>
        <p class="text-secondary reveal mt-4 text-[length:var(--text-small)]">{en.hero.socialProof}</p>
        <div class="reveal mt-8 flex justify-center">
          <AppStoreBadges locale="en" campaign="hero" />
        </div>
      </div>
    </div>
  </section>

  <!-- Day Story Section -->
  <section class="section" id="day-story">
    <div class="container">
      <div class="content">
        <h2 class="reveal mb-16 text-center text-[length:var(--text-h2)] font-bold">{en.dayStory.sectionTitle}</h2>
        <div class="space-y-24">
          {
            [
              en.dayStory.morning,
              en.dayStory.breakfast,
              en.dayStory.training,
              en.dayStory.evening,
              en.dayStory.night,
            ].map((scene, i) => (
              <div
                class={`day-scene flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} items-center gap-12`}
              >
                <div class="flex-1">
                  <span class="day-time text-flexen-accent mb-2 block font-mono text-[length:var(--text-small)]">
                    {scene.time}
                  </span>
                  <h3 class="day-title mb-4 text-[length:var(--text-h3)] font-bold">{scene.title}</h3>
                  <p class="day-description text-secondary text-body">{scene.description}</p>
                </div>
                <div class="day-mockup bg-flexen-dark-mid aspect-[9/16] max-w-[300px] flex-1 rounded-3xl border border-white/5" />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Features Bento Grid -->
  <section class="section" id="features">
    <div class="container">
      <div class="content">
        <h2 class="reveal mb-4 text-center text-[length:var(--text-h2)] font-bold">{en.features.sectionTitle}</h2>
        <p class="text-secondary reveal text-body mb-16 text-center">
          {en.features.sectionSubtitle}
        </p>
        <div class="stagger-children grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <div
            class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-8 md:col-span-2 lg:col-span-2"
          >
            <span class="gradient-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium text-white"
              >{en.features.julio.badge}</span
            >
            <h3 class="mb-3 text-[length:var(--text-h3)] font-bold">{en.features.julio.title}</h3>
            <p class="text-secondary text-body">{en.features.julio.description}</p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-8">
            <span class="bg-success/20 text-success mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >{en.features.foodAI.badge}</span
            >
            <h3 class="mb-3 text-[length:var(--text-h3)] font-bold">{en.features.foodAI.title}</h3>
            <p class="text-secondary text-body">{en.features.foodAI.description}</p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-8">
            <span
              class="bg-flexen-accent/20 text-flexen-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >{en.features.training.badge}</span
            >
            <h3 class="mb-3 text-[length:var(--text-h3)] font-bold">{en.features.training.title}</h3>
            <p class="text-secondary text-body">{en.features.training.description}</p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-8">
            <h3 class="mb-3 text-[length:var(--text-h3)] font-bold">{en.features.sleep.title}</h3>
            <p class="text-secondary text-body">{en.features.sleep.description}</p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-8">
            <h3 class="mb-3 text-[length:var(--text-h3)] font-bold">{en.features.journal.title}</h3>
            <p class="text-secondary text-body">{en.features.journal.description}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="section" id="social-proof">
    <div class="container">
      <div class="content">
        <h2 class="reveal mb-16 text-center text-[length:var(--text-h2)] font-bold">{en.socialProof.sectionTitle}</h2>
        <div class="stagger-children mb-20 grid grid-cols-1 gap-8 md:grid-cols-3">
          {
            en.socialProof.stats.map((stat) => (
              <div class="text-center">
                <span
                  class="text-flexen-accent block text-[length:var(--text-h1)] font-bold"
                  data-count-target={stat.value}
                  data-count-suffix={stat.suffix}
                >
                  {stat.value}
                  {stat.suffix}
                </span>
                <span class="text-secondary text-body">{stat.label}</span>
              </div>
            ))
          }
        </div>
        <div class="stagger-children grid grid-cols-1 gap-6 md:grid-cols-3">
          {
            en.socialProof.testimonials.map((testimonial) => (
              <div class="gradient-card card-hover rounded-2xl border border-white/5 p-8">
                <p class="text-secondary text-body mb-6 italic">&ldquo;{testimonial.text}&rdquo;</p>
                <div class="flex items-center justify-between">
                  <div>
                    <span class="block font-semibold">{testimonial.name}</span>
                    <span class="text-tertiary text-[length:var(--text-small)]">{testimonial.role}</span>
                  </div>
                  <span class="text-flexen-accent text-[length:var(--text-small)] font-semibold">
                    {testimonial.result}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" id="pricing">
    <div class="container">
      <div class="content">
        <h2 class="reveal mb-4 text-center text-[length:var(--text-h2)] font-bold">{en.pricing.sectionTitle}</h2>
        <p class="text-secondary reveal text-body mb-16 text-center">
          {en.pricing.sectionSubtitle}
        </p>
        <div class="stagger-children mx-auto grid max-w-4xl grid-cols-1 gap-8 md:grid-cols-2">
          <div class="gradient-card rounded-2xl border border-white/5 p-8">
            <h3 class="mb-1 text-[length:var(--text-h3)] font-bold">{en.pricing.free.name}</h3>
            <p class="text-tertiary mb-6">{en.pricing.free.subtitle}</p>
            <div class="mb-6">
              <span class="text-[length:var(--text-h1)] font-bold">${en.pricing.free.price}</span>
              <span class="text-tertiary ml-2">{en.pricing.free.period}</span>
            </div>
            <a
              href="#"
              class="mb-8 block w-full rounded-xl border border-white/10 py-3 text-center font-medium text-white transition-colors hover:bg-white/5"
              >{en.pricing.free.cta}</a
            >
            <ul class="space-y-3">
              {
                en.pricing.free.features.map((f) => (
                  <li class="text-secondary flex items-start gap-3">
                    <>
                      <span class="text-success mt-0.5">&#10003;</span>
                      <span>{f}</span>
                    </>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="border-flexen-accent gradient-card relative rounded-2xl border-2 p-8">
            <span
              class="gradient-accent absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-4 py-1 text-xs font-semibold text-white"
              >{en.pricing.premium.popular}</span
            >
            <h3 class="mb-1 text-[length:var(--text-h3)] font-bold">{en.pricing.premium.name}</h3>
            <p class="text-tertiary mb-6">{en.pricing.premium.subtitle}</p>
            <div class="mb-6">
              <span class="text-[length:var(--text-h1)] font-bold">${en.pricing.premium.priceMonthly}</span>
              <span class="text-tertiary ml-2">{en.pricing.premium.period}</span>
            </div>
            <a
              href="#"
              class="btn-glow gradient-accent mb-8 block w-full rounded-xl py-3 text-center font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
              >{en.pricing.premium.cta}</a
            >
            <ul class="space-y-3">
              {
                en.pricing.premium.features.map((f) => (
                  <li class="text-secondary flex items-start gap-3">
                    <>
                      <span class="text-success mt-0.5">&#10003;</span>
                      <span>{f}</span>
                    </>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
        <p class="text-tertiary reveal mt-8 text-center">{en.pricing.guarantee}</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <div class="content mx-auto max-w-3xl">
        <h2 class="reveal mb-16 text-center text-[length:var(--text-h2)] font-bold">{en.faq.sectionTitle}</h2>
        <div class="stagger-children space-y-4">
          {
            en.faq.items.map((item) => (
              <details class="group gradient-card cursor-pointer rounded-2xl border border-white/5 p-6">
                <summary class="text-body flex list-none items-center justify-between font-semibold">
                  {item.question}
                  <span class="text-flexen-accent text-xl transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="text-secondary text-body mt-4 border-t border-white/5 pt-4">{item.answer}</p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <NewsletterSignup locale="en" variant="card" />

  <!-- Final CTA -->
  <section class="section gradient-hero">
    <div class="container">
      <div class="content text-center">
        <h2 class="reveal mb-6 text-[length:var(--text-h1)] font-bold">{en.finalCta.headline}</h2>
        <p class="text-secondary reveal text-body mx-auto mb-8">{en.finalCta.subline}</p>
        <a
          href="#"
          class="btn-glow gradient-accent reveal inline-flex items-center justify-center rounded-xl px-10 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
          >{en.finalCta.cta}</a
        >
        <div class="reveal mt-8 flex justify-center">
          <AppStoreBadges locale="en" campaign="final_cta" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
