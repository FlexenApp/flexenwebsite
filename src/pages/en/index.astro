---
import BaseLayout from '../../layouts/BaseLayout.astro'
import MinimalLanding from '../../components/astro/MinimalLanding.astro'

const meta = {
  title: 'Flexen UG — AI tools for fitness & everyday life',
  description:
    'Flexen UG is a small German software company. We build Flexen (AI coach for fitness, nutrition & wellbeing) and Project Pluto (personal AI assistant with memory).',
}
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  locale="en"
  canonicalPath="/en/"
  hideNav
  hideFooter
>
  <MinimalLanding locale="en" />
</BaseLayout>
