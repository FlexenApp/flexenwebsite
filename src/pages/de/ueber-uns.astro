---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'
import de from '../../i18n/de.json'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Startseite', url: 'https://flexen.app/de/' },
  { name: 'Über uns', url: 'https://flexen.app/de/ueber-uns' },
])
---

<BaseLayout
  title="Über uns — Flexen"
  description="Die Geschichte hinter Flexen: Warum wir eine KI-gestützte Gesundheits-App bauen, die Fitness, Ernährung, Schlaf und Mental Health in einer App vereint."
  locale="de"
  canonicalPath="/de/ueber-uns"
  schema={breadcrumbSchema}
>
  <!-- Hero Section -->
  <section class="section gradient-hero flex min-h-[70vh] items-center pt-32">
    <div class="container">
      <div class="content mx-auto max-w-3xl text-center">
        <span class="gradient-accent reveal mb-6 inline-block rounded-full px-4 py-1.5 text-xs font-medium text-white"
          >Unsere Geschichte</span
        >
        <h1 class="reveal mb-6 text-hero font-bold">Die Geschichte hinter Flexen</h1>
        <p class="text-secondary reveal text-body mx-auto mb-8">
          Flexen entstand aus einer simplen Frustration: Warum braucht man 5 Apps, wenn eine alles kann? Kalorienzähler
          hier, Trainingsplan dort, Schlaf-Tracker drüben — und nichts davon spricht miteinander. Wir wollten das
          ändern.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="section" id="mission">
    <div class="container">
      <div class="content mx-auto max-w-4xl">
        <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
          <div>
            <h2 class="reveal mb-6 text-h2 font-bold">
              Ganzheitliche Gesundheit, zugänglich für alle
            </h2>
            <p class="text-secondary reveal text-body mb-4">
              Unsere Vision: KI und Gesundheitsdaten so verbinden, dass jeder Mensch Zugang zu einem persönlichen Coach
              hat — nicht nur die, die sich einen Trainer leisten können.
            </p>
            <p class="text-secondary reveal text-body">
              Wer ganzheitlich gesund leben will, braucht keine fünf verschiedenen Abos. Flexen vereint Ernährung,
              Training, Schlaf, mentale Gesundheit und KI-Coaching in einer einzigen App. Persönlich. Intelligent.
              Bezahlbar.
            </p>
          </div>
          <div class="gradient-card reveal rounded-2xl border border-white/5 p-8">
            <blockquote class="text-secondary text-body italic">
              &bdquo;Gesundheit ist kein Luxus. Jeder verdient einen Coach, der seine Daten kennt, seine Ziele versteht
              und rund um die Uhr verfügbar ist.&ldquo;
            </blockquote>
            <p class="text-flexen-accent mt-4 text-small font-semibold">— Das Flexen-Team</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What makes Flexen different -->
  <section class="section" id="unterschied">
    <div class="container">
      <div class="content">
        <h2 class="reveal mb-4 text-center text-h2 font-bold">Was Flexen anders macht</h2>
        <p class="text-secondary reveal text-body mx-auto mb-16 max-w-2xl text-center">
          Drei Prinzipien, die alles bestimmen was wir bauen.
        </p>
        <div class="stagger-children grid grid-cols-1 gap-6 md:grid-cols-3">
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-8">
            <span class="gradient-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium text-white"
              >KI-Powered</span
            >
            <h3 class="mb-3 text-h3 font-bold">KI als Coach, nicht als Gimmick</h3>
            <p class="text-secondary text-body">
              Julio ist kein Marketing-Feature. Er hat Zugriff auf deine Daten und kann aktiv handeln: Pläne erstellen,
              Fortschritte analysieren, Empfehlungen geben. Ein echter Coach, der dazulernt.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-8">
            <span class="bg-success/20 text-success mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >Ganzheitlich</span
            >
            <h3 class="mb-3 text-h3 font-bold">Ganzheitlich statt fragmentiert</h3>
            <p class="text-secondary text-body">
              Ernährung beeinflusst Schlaf. Schlaf beeinflusst Training. Training beeinflusst Stimmung. Flexen versteht
              diese Zusammenhänge — weil alle Daten an einem Ort sind.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-white/5 p-8">
            <span
              class="bg-flexen-accent/20 text-flexen-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >Datenschutz</span
            >
            <h3 class="mb-3 text-h3 font-bold">Deine Daten gehören dir</h3>
            <p class="text-secondary text-body">
              Gesundheitsdaten sind das Persönlichste was es gibt. Wir verkaufen sie nicht, teilen sie nicht und werden
              das auch nie tun. Deine Daten bleiben deine Daten. Punkt.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech/KI Section -->
  <section class="section" id="technologie">
    <div class="container">
      <div class="content mx-auto max-w-4xl">
        <h2 class="reveal mb-4 text-center text-h2 font-bold">Die Technologie hinter Flexen</h2>
        <p class="text-secondary reveal text-body mx-auto mb-16 max-w-2xl text-center">
          Modernste KI, nahtlos in deinen Alltag integriert.
        </p>
        <div class="stagger-children space-y-6">
          <div
            class="gradient-card card-hover flex flex-col items-start gap-6 rounded-2xl border border-white/5 p-8 md:flex-row"
          >
            <div class="gradient-accent flex h-12 w-12 shrink-0 items-center justify-center rounded-xl">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
                ></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="mb-2 text-h3 font-bold">Computer Vision für Essenserkennung</h3>
              <p class="text-secondary text-body">
                Flexens KI analysiert Fotos deiner Mahlzeiten in Echtzeit. Über 10.000 Lebensmittel werden erkannt — mit
                Kalorien, Makros und Portionsgrößen. Kein manuelles Eintippen, kein Raten.
              </p>
            </div>
          </div>
          <div
            class="gradient-card card-hover flex flex-col items-start gap-6 rounded-2xl border border-white/5 p-8 md:flex-row"
          >
            <div class="gradient-accent flex h-12 w-12 shrink-0 items-center justify-center rounded-xl">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="mb-2 text-h3 font-bold">LLM mit Function Calling für Julio</h3>
              <p class="text-secondary text-body">
                Julio ist mehr als ein Chatbot. Durch Function Calling kann er aktiv auf deine Daten zugreifen und
                Aktionen ausführen: Trainingspläne erstellen, Mahlzeiten analysieren, Schlafmuster erkennen — alles in
                natürlicher Sprache.
              </p>
            </div>
          </div>
          <div
            class="gradient-card card-hover flex flex-col items-start gap-6 rounded-2xl border border-white/5 p-8 md:flex-row"
          >
            <div class="gradient-accent flex h-12 w-12 shrink-0 items-center justify-center rounded-xl">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="mb-2 text-h3 font-bold">Health Connect & HealthKit Integration</h3>
              <p class="text-secondary text-body">
                Flexen verbindet sich nahtlos mit dem Gesundheits-Ökosystem deines Smartphones. Schlaf, Schritte,
                Herzfrequenz — alles fließt automatisch zusammen. Kein zusätzliches Wearable nötig.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section gradient-hero">
    <div class="container">
      <div class="content text-center">
        <h2 class="reveal mb-6 text-h1 font-bold">{de.finalCta.headline}</h2>
        <p class="text-secondary reveal text-body mx-auto mb-8">{de.finalCta.subline}</p>
        <a
          href="#"
          class="btn-glow gradient-accent reveal inline-flex items-center justify-center rounded-xl px-10 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
          >{de.finalCta.cta}</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
