---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Startseite', url: 'https://flexen.app/de/' },
  { name: 'Impressum', url: 'https://flexen.app/de/impressum' },
])
---

<BaseLayout
  title="Impressum — Flexen"
  description="Impressum und Anbieterkennzeichnung der Flexen App."
  locale="de"
  canonicalPath="/de/impressum"
  schema={breadcrumbSchema}
>
  <section class="section min-h-screen">
    <div class="container">
      <div class="content max-w-3xl">
        <h1 class="font-heading mb-12 text-[length:var(--text-h1)] font-bold">Impressum</h1>

        <div class="prose prose-invert text-secondary space-y-8 text-[length:var(--text-body)]">
          <div>
            <h2 class="font-heading mb-4 text-[length:var(--text-h3)] font-bold text-white">
              Angaben gem&auml;&szlig; &sect; 5 DDG
            </h2>
            <p>
              <strong class="text-white">[Firmenname]</strong><br />
              [Stra&szlig;e + Hausnummer]<br />
              [PLZ + Stadt]<br />
              Deutschland
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-[length:var(--text-h3)] font-bold text-white">Kontakt</h2>
            <p>
              E-Mail: <a href="mailto:kontakt@flexen.app" class="text-flexen-accent hover:underline"
                >kontakt@flexen.app</a
              ><br />
              Telefon: [+49 XXX XXXXXXX]
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-[length:var(--text-h3)] font-bold text-white">Registereintrag</h2>
            <p>
              Registergericht: [Amtsgericht]<br />
              Registernummer: [HRB XXXXX]<br />
              Gesch&auml;ftsf&uuml;hrer: [Name]
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-[length:var(--text-h3)] font-bold text-white">Umsatzsteuer-ID</h2>
            <p>
              Umsatzsteuer-Identifikationsnummer gem&auml;&szlig; &sect; 27a UStG:<br />
              DE XXXXXXXXX
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-[length:var(--text-h3)] font-bold text-white">
              Verantwortlich f&uuml;r den Inhalt
            </h2>
            <p>
              gem&auml;&szlig; &sect; 18 Abs. 2 MStV:<br />
              [Name]<br />
              [Adresse]
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-[length:var(--text-h3)] font-bold text-white">Streitschlichtung</h2>
            <p>
              Die Europ&auml;ische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
              <a
                href="https://ec.europa.eu/consumers/odr/"
                target="_blank"
                rel="noopener"
                class="text-flexen-accent hover:underline">https://ec.europa.eu/consumers/odr/</a
              >.
            </p>
            <p>
              Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer
              Verbraucherschlichtungsstelle teilzunehmen.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
