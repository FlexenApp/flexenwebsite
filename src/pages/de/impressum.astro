---
import MinimalLegalLayout from '../../layouts/MinimalLegalLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Startseite', url: 'https://flexen.co/de/' },
  { name: 'Impressum', url: 'https://flexen.co/de/impressum' },
])
---

<MinimalLegalLayout
  title="Impressum — Flexen UG"
  description="Impressum und Anbieterkennzeichnung der Flexen UG (haftungsbeschränkt)."
  locale="de"
  canonicalPath="/de/impressum"
  schema={breadcrumbSchema}
>
  <section class="section min-h-screen">
    <div class="container">
      <div class="content max-w-3xl">
        <h1 class="font-heading mb-4 text-h1 font-bold">Impressum</h1>
        <p class="text-secondary text-body mb-12">
          Dieses Impressum gilt f&uuml;r die Website
          <strong class="text-white">flexen.co</strong> sowie f&uuml;r alle Produkte der
          Flexen UG (haftungsbeschr&auml;nkt) — derzeit
          <strong class="text-white">Flexen</strong> und
          <strong class="text-white">Project Pluto</strong>.
        </p>

        <div class="prose prose-invert text-secondary text-body space-y-8">
          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">
              Angaben gem&auml;&szlig; &sect; 5 DDG
            </h2>
            <p>
              <strong class="text-white">Flexen UG (haftungsbeschr&auml;nkt)</strong><br />
              Paul-Heidelbach-Stra&szlig;e 14<br />
              34134 Kassel<br />
              Deutschland
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">Kontakt</h2>
            <p>
              E-Mail: <a href="mailto:info@flexen.co" class="text-flexen-accent hover:underline"
                >info@flexen.co</a
              >
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">Registereintrag</h2>
            <p>
              Registergericht: Amtsgericht Kassel<br />
              Registernummer: HRB 20498<br />
              Gesch&auml;ftsf&uuml;hrer: Leonard Hoppe, Marcel Schneider, Leon Schmelzle
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">Umsatzsteuer-ID</h2>
            <p>
              Umsatzsteuer-Identifikationsnummer gem&auml;&szlig; &sect; 27a UStG:<br />
              DE459052032
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">
              Verantwortlich f&uuml;r den Inhalt
            </h2>
            <p>
              gem&auml;&szlig; &sect; 18 Abs. 2 MStV:<br />
              Leonard Hoppe<br />
              Paul-Heidelbach-Stra&szlig;e 14, 34134 Kassel
            </p>
          </div>

          <div>
            <h2 class="font-heading mb-4 text-h3 font-bold text-white">Streitschlichtung</h2>
            <p>
              Die Europ&auml;ische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
              <a
                href="https://ec.europa.eu/consumers/odr/"
                target="_blank"
                rel="noopener"
                class="text-flexen-accent hover:underline">https://ec.europa.eu/consumers/odr/</a
              >.
            </p>
            <p>
              Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer
              Verbraucherschlichtungsstelle teilzunehmen.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</MinimalLegalLayout>
