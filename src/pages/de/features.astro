---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBreadcrumbSchema } from '../../lib/seo'
import de from '../../i18n/de.json'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Startseite', url: 'https://flexen.app/de/' },
  { name: 'Features', url: 'https://flexen.app/de/features' },
])
---

<BaseLayout
  title="Alle Features — Flexen Fitness App"
  description="Entdecke Flexens KI-Coach Julio, automatische Essenserkennung, personalisierte Trainingspläne und Schlaf-Tracking."
  locale="de"
  canonicalPath="/de/features"
  schema={breadcrumbSchema}
>
  <!-- Hero Section -->
  <section class="section gradient-hero flex min-h-[70vh] items-center pt-32">
    <div class="container">
      <div class="content text-center">
        <h1 class="reveal mb-6 text-hero font-bold">
          {de.features.sectionTitle}
        </h1>
        <p class="text-secondary reveal text-body mx-auto mb-8 max-w-2xl">
          {de.features.sectionSubtitle}
        </p>
        <div class="reveal flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="#julio"
            class="inline-flex items-center justify-center rounded-xl border border-border px-8 py-4 font-medium text-white/80 transition-colors hover:bg-white/5"
          >
            Features entdecken
          </a>
          <a
            href="#"
            class="btn-glow gradient-accent inline-flex items-center justify-center rounded-xl px-8 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
          >
            {de.hero.cta}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Julio -->
  <section class="section" id="julio">
    <div class="container">
      <div class="content">
        <div class="flex flex-col items-center gap-16 md:flex-row">
          <div class="reveal flex-1">
            <span class="gradient-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium text-white"
              >{de.features.julio.badge}</span
            >
            <h2 class="mb-4 text-h2 font-bold">{de.features.julio.title}</h2>
            <p class="text-secondary text-body mb-8">{de.features.julio.description}</p>
            <ul class="stagger-children space-y-4">
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Echtzeit-Trainingspläne</span>
                  <p class="mt-1 text-small">
                    Sag Julio dein Ziel — er baut dir den Plan in Sekunden. Angepasst an dein Level und Equipment.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Ernährungsberatung mit deinen Daten</span>
                  <p class="mt-1 text-small">
                    Julio kennt dein Kalorienziel, deine Vorlieben und Allergien. Er schlägt vor, was du essen solltest.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Schlaf-Tipps basierend auf deinen Mustern</span>
                  <p class="mt-1 text-small">
                    Er analysiert deine Schlafhistorie und gibt dir konkrete Tipps für bessere Erholung.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Natürliche Sprache</span>
                  <p class="mt-1 text-small">
                    Kein Menü-Klicken. Schreib einfach was du willst — Julio versteht dich.
                  </p>
                </div>
              </li>
            </ul>
          </div>
          <div class="reveal flex flex-1 justify-center">
            <div class="w-full max-w-[300px] overflow-hidden rounded-[2.5rem] shadow-2xl shadow-flexen-accent/5">
              <img
                src="/images/app/julio-chat.svg"
                alt="Flexen App: KI-Coach Julio Chat"
                class="h-auto w-full"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Food AI -->
  <section class="section" id="food-ai">
    <div class="container">
      <div class="content">
        <div class="flex flex-col items-center gap-16 md:flex-row-reverse">
          <div class="reveal flex-1">
            <span class="bg-success/20 text-success mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >{de.features.foodAI.badge}</span
            >
            <h2 class="mb-4 text-h2 font-bold">{de.features.foodAI.title}</h2>
            <p class="text-secondary text-body mb-8">{de.features.foodAI.description}</p>
            <ul class="stagger-children space-y-4">
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Über 10.000 Lebensmittel</span>
                  <p class="mt-1 text-small">
                    Unsere KI erkennt Gerichte, einzelne Zutaten und sogar zusammengestellte Teller mit ca. 90%
                    Genauigkeit.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Barcode-Scanner</span>
                  <p class="mt-1 text-small">
                    Verpackte Produkte einfach scannen — Nährwerte werden automatisch aus unserer Datenbank geladen.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Lernt aus deinen Korrekturen</span>
                  <p class="mt-1 text-small">
                    Korrigierst du ein Ergebnis, merkt sich die KI das. Je öfter du sie nutzt, desto genauer wird sie.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Automatische Makro-Berechnung</span>
                  <p class="mt-1 text-small">
                    Kalorien, Protein, Kohlenhydrate, Fett — alles wird sofort berechnet und in dein Tagesprotokoll
                    eingetragen.
                  </p>
                </div>
              </li>
            </ul>
          </div>
          <div class="reveal flex flex-1 justify-center">
            <div class="w-full max-w-[300px] overflow-hidden rounded-[2.5rem] shadow-2xl shadow-success/5">
              <img
                src="/images/app/food-recognition.svg"
                alt="Flexen App: KI-Essenserkennung"
                class="h-auto w-full"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Training -->
  <section class="section" id="training">
    <div class="container">
      <div class="content">
        <div class="flex flex-col items-center gap-16 md:flex-row">
          <div class="reveal flex-1">
            <span
              class="bg-flexen-accent/20 text-flexen-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >{de.features.training.badge}</span
            >
            <h2 class="mb-4 text-h2 font-bold">{de.features.training.title}</h2>
            <p class="text-secondary text-body mb-8">{de.features.training.description}</p>
            <ul class="stagger-children space-y-4">
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Progressive Overload automatisch</span>
                  <p class="mt-1 text-small">
                    Julio erhöht Gewicht und Volumen basierend auf deinem Fortschritt — du musst nicht selbst rechnen.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Eingebauter Timer</span>
                  <p class="mt-1 text-small">
                    Satz-Timer und Pausenzeiten laufen automatisch. Vibration wenn die nächste Übung dran ist.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Übungsanleitungen mit Videos</span>
                  <p class="mt-1 text-small">
                    Jede Übung wird erklärt — mit korrekter Ausführung und typischen Fehlern.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Flexibel bei Equipment</span>
                  <p class="mt-1 text-small">
                    Gym, Homegym oder Bodyweight — Julio passt den Plan an das an, was dir zur Verfügung steht.
                  </p>
                </div>
              </li>
            </ul>
          </div>
          <div class="reveal flex flex-1 justify-center">
            <div class="w-full max-w-[300px] overflow-hidden rounded-[2.5rem] shadow-2xl shadow-flexen-accent/5">
              <img
                src="/images/app/training.svg"
                alt="Flexen App: Training"
                class="h-auto w-full"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Sleep -->
  <section class="section" id="sleep">
    <div class="container">
      <div class="content">
        <div class="flex flex-col items-center gap-16 md:flex-row-reverse">
          <div class="reveal flex-1">
            <h2 class="mb-4 text-h2 font-bold">{de.features.sleep.title}</h2>
            <p class="text-secondary text-body mb-8">{de.features.sleep.description}</p>
            <ul class="stagger-children space-y-4">
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Automatisches Tracking</span>
                  <p class="mt-1 text-small">
                    Über Health Connect und HealthKit — kein Wearable nötig, aber kompatibel mit allen gängigen Geräten.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Schlafphasen-Analyse</span>
                  <p class="mt-1 text-small">
                    Sieh genau, wie viel Tiefschlaf und REM-Schlaf du bekommst — und was das für deine Erholung
                    bedeutet.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Muster erkennen</span>
                  <p class="mt-1 text-small">
                    Flexen zeigt dir Trends über Wochen und Monate — erkenne, was deinen Schlaf verbessert oder
                    verschlechtert.
                  </p>
                </div>
              </li>
            </ul>
          </div>
          <div class="reveal flex flex-1 justify-center">
            <div class="w-full max-w-[300px] overflow-hidden rounded-[2.5rem] shadow-2xl shadow-purple-500/5">
              <img
                src="/images/app/sleep.svg"
                alt="Flexen App: Schlaf-Tracking"
                class="h-auto w-full"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Journal -->
  <section class="section" id="journal">
    <div class="container">
      <div class="content">
        <div class="flex flex-col items-center gap-16 md:flex-row">
          <div class="reveal flex-1">
            <h2 class="mb-4 text-h2 font-bold">{de.features.journal.title}</h2>
            <p class="text-secondary text-body mb-8">{de.features.journal.description}</p>
            <ul class="stagger-children space-y-4">
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Spracheingabe</span>
                  <p class="mt-1 text-small">
                    Sprich einfach drauflos — Flexen wandelt deine Worte in Text um. Journaling ohne tippen.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Stimmungs-Tracking</span>
                  <p class="mt-1 text-small">
                    Erfasse deine Stimmung mit einem Tap. Sieh über Wochen, wie sich Training und Ernährung auf dein
                    Wohlbefinden auswirken.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Tägliche Schreibimpulse</span>
                  <p class="mt-1 text-small">
                    Keine Idee was du schreiben sollst? Flexen gibt dir jeden Tag einen neuen Impuls für Reflexion und
                    Achtsamkeit.
                  </p>
                </div>
              </li>
              <li class="text-secondary flex items-start gap-3">
                <span class="text-flexen-accent mt-0.5 shrink-0">&#10148;</span>
                <div>
                  <span class="font-medium text-white">Alles verbunden</span>
                  <p class="mt-1 text-small">
                    Dein Journal ist verknüpft mit Training, Schlaf und Ernährung. Julio erkennt Zusammenhänge, die du
                    allein nicht siehst.
                  </p>
                </div>
              </li>
            </ul>
          </div>
          <div class="reveal flex flex-1 justify-center">
            <div class="w-full max-w-[300px] overflow-hidden rounded-[2.5rem] shadow-2xl shadow-amber-500/5">
              <img
                src="/images/app/journal.svg"
                alt="Flexen App: Journal & Stimmung"
                class="h-auto w-full"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- All Features Overview -->
  <section class="section">
    <div class="container">
      <div class="content">
        <h2 class="reveal mb-4 text-center text-h2 font-bold">Alles auf einen Blick</h2>
        <p class="text-secondary reveal text-body mb-16 text-center">Was in Free und Premium enthalten ist.</p>
        <div class="stagger-children grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-6">
            <div
              class="gradient-accent mb-4 flex h-10 w-10 items-center justify-center rounded-xl font-bold text-white"
            >
              J
            </div>
            <h3 class="mb-2 text-lg font-semibold">KI-Coach Julio</h3>
            <p class="text-secondary text-small">
              Unbegrenzte Anfragen mit Premium. 3 pro Tag in Free.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-6">
            <div
              class="bg-success/20 text-success mb-4 flex h-10 w-10 items-center justify-center rounded-xl font-bold"
            >
              F
            </div>
            <h3 class="mb-2 text-lg font-semibold">Foto-Essenserkennung</h3>
            <p class="text-secondary text-small">
              KI-gestützt in Premium. Manuelles Logging in Free.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-6">
            <div
              class="bg-flexen-accent/20 text-flexen-accent mb-4 flex h-10 w-10 items-center justify-center rounded-xl font-bold"
            >
              T
            </div>
            <h3 class="mb-2 text-lg font-semibold">Trainingspläne</h3>
            <p class="text-secondary text-small">
              Unbegrenzte Pläne in Premium. 1 aktiver Plan in Free.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-6">
            <div
              class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-purple-500/20 font-bold text-purple-400"
            >
              S
            </div>
            <h3 class="mb-2 text-lg font-semibold">Schlaf-Tracking</h3>
            <p class="text-secondary text-small">
              Erweiterte Analysen in Premium. Basis-Tracking in Free.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-6">
            <div
              class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-500/20 font-bold text-amber-400"
            >
              M
            </div>
            <h3 class="mb-2 text-lg font-semibold">Journal & Mental Health</h3>
            <p class="text-secondary text-small">
              Voice-Journal und Impulse in Premium. Basis-Journal in Free.
            </p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-6">
            <div
              class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-rose-500/20 font-bold text-rose-400"
            >
              +
            </div>
            <h3 class="mb-2 text-lg font-semibold">Keine Werbung</h3>
            <p class="text-secondary text-small">
              Premium ist komplett werbefrei. Deine Daten werden nie verkauft.
            </p>
          </div>
        </div>
        <div class="reveal mt-12 text-center">
          <a
            href="/de/#pricing"
            class="inline-flex items-center justify-center rounded-xl border border-border px-8 py-4 font-medium text-white/80 transition-colors hover:bg-white/5"
          >
            Preise vergleichen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section gradient-hero">
    <div class="container">
      <div class="content text-center">
        <h2 class="reveal mb-6 text-h1 font-bold">{de.finalCta.headline}</h2>
        <p class="text-secondary reveal text-body mx-auto mb-8">{de.finalCta.subline}</p>
        <a
          href="#"
          class="btn-glow gradient-accent reveal inline-flex items-center justify-center rounded-xl px-10 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
          >{de.finalCta.cta}</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
