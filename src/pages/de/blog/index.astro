---
import { getCollection } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getBreadcrumbSchema } from '../../../lib/seo'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Startseite', url: 'https://flexen.app/de/' },
  { name: 'Blog', url: 'https://flexen.app/de/blog' },
])

const posts = (await getCollection('blog'))
  .filter((post) => post.data.locale === 'de' && !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const categoryLabels = {
  ernaehrung: 'Ernährung',
  training: 'Training',
  'ki-tech': 'KI & Tech',
  erfolgsgeschichten: 'Erfolgsgeschichten',
}
---

<BaseLayout
  title="Blog — Flexen"
  description="Tipps zu Fitness, Ernährung, Schlaf und KI. Der Flexen Blog."
  locale="de"
  canonicalPath="/de/blog"
  schema={breadcrumbSchema}
>
  <section class="section">
    <div class="container">
      <div class="content">
        <h1 class="text-[length:var(--text-h1)] font-bold mb-4 font-heading reveal">Blog</h1>
        <p class="text-secondary text-[length:var(--text-body)] mb-16 reveal">
          Tipps, Guides und Insights zu Fitness, Ernährung und KI.
        </p>

        {posts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
            {posts.map((post) => (
              <a href={`/de/blog/${post.id}/`} class="group p-6 rounded-2xl gradient-card border border-white/5 card-hover gradient-border block">
                <div class="flex items-center gap-3 mb-4">
                  <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-flexen-accent/15 text-flexen-accent">
                    {categoryLabels[post.data.category] || post.data.category}
                  </span>
                  <time class="text-xs text-tertiary" datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('de-DE', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                </div>
                <h2 class="text-lg font-bold mb-2 font-heading group-hover:text-flexen-accent transition-colors">{post.data.title}</h2>
                <p class="text-secondary text-sm line-clamp-3">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <div class="p-8 rounded-2xl gradient-card border border-white/5 text-center">
            <p class="text-tertiary">Bald erscheinen hier unsere ersten Artikel.</p>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
