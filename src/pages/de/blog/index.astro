---
import { getCollection } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getBreadcrumbSchema } from '../../../lib/seo'

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Startseite', url: 'https://flexen.app/de/' },
  { name: 'Blog', url: 'https://flexen.app/de/blog' },
])

const posts = (await getCollection('blog'))
  .filter((post) => post.data.locale === 'de' && !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const categoryLabels = {
  ernaehrung: 'Ernährung',
  training: 'Training',
  'ki-tech': 'KI & Tech',
  erfolgsgeschichten: 'Erfolgsgeschichten',
}
---

<BaseLayout
  title="Blog — Flexen | Fitness, Ernährung & KI"
  description="Tipps zu Fitness, Ernährung, Schlaf und KI. Der Flexen Blog."
  locale="de"
  canonicalPath="/de/blog"
  schema={breadcrumbSchema}
>
  <section class="section">
    <div class="container">
      <div class="content">
        <h1 class="font-heading reveal mb-4 text-[length:var(--text-h1)] font-bold">Blog</h1>
        <p class="text-secondary reveal text-body mb-16">Tipps, Guides und Insights zu Fitness, Ernährung und KI.</p>

        {
          posts.length > 0 ? (
            <div class="stagger-children grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
              {posts.map((post) => (
                <a
                  href={`/de/blog/${post.id}/`}
                  class="group gradient-card card-hover gradient-border block rounded-2xl border border-white/5 p-6"
                >
                  <div class="mb-4 flex items-center gap-3">
                    <span class="bg-flexen-accent/15 text-flexen-accent inline-block rounded-full px-2.5 py-0.5 text-xs font-medium">
                      {categoryLabels[post.data.category] || post.data.category}
                    </span>
                    <time class="text-tertiary text-xs" datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('de-DE', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                  </div>
                  <h2 class="font-heading group-hover:text-flexen-accent mb-2 text-lg font-bold transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-secondary line-clamp-3 text-sm">{post.data.description}</p>
                </a>
              ))}
            </div>
          ) : (
            <div class="gradient-card rounded-2xl border border-white/5 p-8 text-center">
              <p class="text-tertiary">Bald erscheinen hier unsere ersten Artikel.</p>
            </div>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
