---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getAppSchema, getFAQSchema } from '../../lib/seo'
import de from '../../i18n/de.json'
import NewsletterSignup from '../../components/astro/NewsletterSignup.astro'
import AppStoreBadges from '../../components/astro/AppStoreBadges.astro'

const schema = getAppSchema()
const faqSchema = getFAQSchema(de.faq.items)
---

<BaseLayout
  title={de.meta.title}
  description={de.meta.description}
  locale="de"
  canonicalPath="/de/"
  schema={[schema, faqSchema]}
>
  <!-- Hero Section -->
  <section class="section gradient-hero flex min-h-screen items-center" aria-label="Hero">
    <div class="container">
      <div class="content text-center">
        <h1 class="font-heading mb-6 text-hero font-bold" data-hero-headline style="opacity:0;">
          {de.hero.headline}
        </h1>
        <p class="text-secondary text-body mx-auto mb-8" data-hero-subline>
          {de.hero.subline}
        </p>
        <div class="mb-6 flex flex-col items-center justify-center gap-4 sm:flex-row" data-hero-ctas>
          <a
            href="#pricing"
            class="btn-glow gradient-accent inline-flex items-center justify-center rounded-xl px-8 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
            data-magnetic
          >
            {de.hero.cta}
          </a>
          <a
            href="/de/features"
            class="inline-flex items-center justify-center rounded-xl border border-border px-8 py-4 font-medium text-white/80 transition-colors hover:bg-white/5"
          >
            {de.hero.ctaSecondary}
          </a>
        </div>
        <p class="text-tertiary reveal text-small">
          {de.hero.microcopy}
        </p>
        <p class="text-secondary reveal mt-4 text-small">
          {de.hero.socialProof}
        </p>
        <div class="reveal mt-8 flex justify-center">
          <AppStoreBadges locale="de" campaign="hero" />
        </div>
      </div>
    </div>
  </section>

  <!-- Day Story Section -->
  <section class="section" id="day-story" aria-labelledby="day-story-title">
    <div class="container">
      <div class="content">
        <h2 id="day-story-title" class="font-heading reveal mb-16 text-center text-h2 font-bold">
          {de.dayStory.sectionTitle}
        </h2>
        <div class="space-y-24">
          {
            [
              de.dayStory.morning,
              de.dayStory.breakfast,
              de.dayStory.training,
              de.dayStory.evening,
              de.dayStory.night,
            ].map((scene, i) => (
              <div
                class={`day-scene flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} items-center gap-12`}
              >
                <div class="flex-1">
                  <span class="day-time text-flexen-accent mb-2 block font-mono text-small">
                    {scene.time}
                  </span>
                  <h3 class="font-heading day-title mb-4 text-h3 font-bold">{scene.title}</h3>
                  <p class="day-description text-secondary text-body">{scene.description}</p>
                </div>
                <div
                  class="day-mockup bg-flexen-dark-mid aspect-[9/16] max-w-[300px] flex-1 rounded-3xl border border-border"
                  role="img"
                  aria-label={`App-Screenshot: ${scene.title}`}
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Features Bento Grid -->
  <section class="section" id="features" aria-labelledby="features-title">
    <div class="container">
      <div class="content">
        <h2 id="features-title" class="font-heading reveal mb-4 text-center text-h2 font-bold">
          {de.features.sectionTitle}
        </h2>
        <p class="text-secondary reveal text-body mb-16 text-center">
          {de.features.sectionSubtitle}
        </p>
        <div class="stagger-children grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <div
            class="gradient-card card-hover gradient-border rounded-2xl border border-border p-8 md:col-span-2 lg:col-span-2"
          >
            <span class="gradient-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium text-white"
              >{de.features.julio.badge}</span
            >
            <h3 class="font-heading mb-3 text-h3 font-bold">{de.features.julio.title}</h3>
            <p class="text-secondary text-body">{de.features.julio.description}</p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-8">
            <span class="bg-success/20 text-success mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >{de.features.foodAI.badge}</span
            >
            <h3 class="font-heading mb-3 text-h3 font-bold">{de.features.foodAI.title}</h3>
            <p class="text-secondary text-body">{de.features.foodAI.description}</p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-8">
            <span
              class="bg-flexen-accent/20 text-flexen-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium"
              >{de.features.training.badge}</span
            >
            <h3 class="font-heading mb-3 text-h3 font-bold">{de.features.training.title}</h3>
            <p class="text-secondary text-body">{de.features.training.description}</p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-8">
            <h3 class="font-heading mb-3 text-h3 font-bold">{de.features.sleep.title}</h3>
            <p class="text-secondary text-body">{de.features.sleep.description}</p>
          </div>
          <div class="gradient-card card-hover gradient-border rounded-2xl border border-border p-8">
            <h3 class="font-heading mb-3 text-h3 font-bold">{de.features.journal.title}</h3>
            <p class="text-secondary text-body">{de.features.journal.description}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="section" id="social-proof" aria-labelledby="social-proof-title">
    <div class="container">
      <div class="content">
        <h2
          id="social-proof-title"
          class="font-heading reveal mb-16 text-center text-h2 font-bold"
        >
          {de.socialProof.sectionTitle}
        </h2>
        <div class="stagger-children mb-20 grid grid-cols-1 gap-8 md:grid-cols-3">
          {
            de.socialProof.stats.map((stat) => (
              <div class="text-center">
                <span
                  class="text-flexen-accent block text-h1 font-bold"
                  data-count-target={stat.value}
                  data-count-suffix={stat.suffix}
                >
                  {stat.value}
                  {stat.suffix}
                </span>
                <span class="text-secondary text-body">{stat.label}</span>
              </div>
            ))
          }
        </div>
        <div class="stagger-children grid grid-cols-1 gap-6 md:grid-cols-3">
          {
            de.socialProof.testimonials.map((t) => (
              <div class="gradient-card card-hover rounded-2xl border border-border p-8">
                <p class="text-secondary text-body mb-6 italic">&ldquo;{t.text}&rdquo;</p>
                <div class="flex items-center justify-between">
                  <div>
                    <span class="block font-semibold">{t.name}</span>
                    <span class="text-tertiary text-small">{t.role}</span>
                  </div>
                  <span class="text-flexen-accent text-small font-semibold">{t.result}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" id="pricing" aria-labelledby="pricing-title">
    <div class="container">
      <div class="content">
        <h2 id="pricing-title" class="font-heading reveal mb-4 text-center text-h2 font-bold">
          {de.pricing.sectionTitle}
        </h2>
        <p class="text-secondary reveal text-body mb-16 text-center">
          {de.pricing.sectionSubtitle}
        </p>
        <div class="stagger-children mx-auto grid max-w-4xl grid-cols-1 gap-8 md:grid-cols-2">
          <div class="gradient-card rounded-2xl border border-border p-8">
            <h3 class="font-heading mb-1 text-h3 font-bold">{de.pricing.free.name}</h3>
            <p class="text-tertiary mb-6">{de.pricing.free.subtitle}</p>
            <div class="mb-6">
              <span class="text-h1 font-bold">{de.pricing.free.price}&euro;</span>
              <span class="text-tertiary ml-2">{de.pricing.free.period}</span>
            </div>
            <a
              href="#newsletter"
              class="mb-8 block w-full rounded-xl border border-border py-3 text-center font-medium text-text-secondary transition-colors hover:bg-bg-soft"
              >{de.pricing.free.cta}</a
            >
            <ul class="space-y-3">
              {
                de.pricing.free.features.map((f) => (
                  <li class="text-secondary flex items-start gap-3">
                    <>
                      <span class="text-success mt-0.5" aria-hidden="true">&#10003;</span>
                      <span>{f}</span>
                    </>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="border-flexen-accent gradient-card relative rounded-2xl border-2 p-8">
            <span
              class="gradient-accent absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-4 py-1 text-xs font-semibold text-white"
              >{de.pricing.premium.popular}</span
            >
            <h3 class="font-heading mb-1 text-h3 font-bold">{de.pricing.premium.name}</h3>
            <p class="text-tertiary mb-6">{de.pricing.premium.subtitle}</p>
            <div class="mb-6">
              <span class="text-h1 font-bold">{de.pricing.premium.priceMonthly}&euro;</span>
              <span class="text-tertiary ml-2">{de.pricing.premium.period}</span>
            </div>
            <a
              href="#newsletter"
              class="btn-glow gradient-accent mb-8 block w-full rounded-xl py-3 text-center font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
              >{de.pricing.premium.cta}</a
            >
            <ul class="space-y-3">
              {
                de.pricing.premium.features.map((f) => (
                  <li class="text-secondary flex items-start gap-3">
                    <>
                      <span class="text-success mt-0.5" aria-hidden="true">&#10003;</span>
                      <span>{f}</span>
                    </>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
        <p class="text-tertiary reveal mt-8 text-center">{de.pricing.guarantee}</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <div class="content mx-auto max-w-3xl">
        <h2 id="faq-title" class="font-heading reveal mb-16 text-center text-h2 font-bold">
          {de.faq.sectionTitle}
        </h2>
        <div class="stagger-children space-y-4">
          {
            de.faq.items.map((item) => (
              <details class="group gradient-card cursor-pointer rounded-2xl border border-border p-6">
                <summary class="text-body flex list-none items-center justify-between font-semibold">
                  {item.question}
                  <span class="text-flexen-accent text-xl transition-transform group-open:rotate-45" aria-hidden="true">+</span>
                </summary>
                <p class="text-secondary text-body mt-4 border-t border-border pt-4">{item.answer}</p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <NewsletterSignup locale="de" variant="card" />

  <!-- Final CTA -->
  <section class="section gradient-hero" aria-label="Call to Action">
    <div class="container">
      <div class="content text-center">
        <h2 class="font-heading reveal mb-6 text-h1 font-bold">{de.finalCta.headline}</h2>
        <p class="text-secondary reveal text-body mx-auto mb-8">{de.finalCta.subline}</p>
        <a
          href="#pricing"
          class="btn-glow gradient-accent reveal inline-flex items-center justify-center rounded-xl px-10 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
          >{de.finalCta.cta}</a
        >
        <div class="reveal mt-8 flex justify-center">
          <AppStoreBadges locale="de" campaign="final_cta" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
