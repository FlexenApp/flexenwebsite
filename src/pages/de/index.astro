---
import BaseLayout from '../../layouts/BaseLayout.astro'
import MinimalLanding from '../../components/astro/MinimalLanding.astro'

const meta = {
  title: 'Flexen UG — KI-Tools für Fitness & Alltag',
  description:
    'Flexen UG ist eine kleine deutsche Software-Firma. Wir bauen Flexen (KI-Coach für Fitness, Ernährung & Wohlbefinden) und Project Pluto (persönlicher KI-Assistent mit Memory).',
}
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  locale="de"
  canonicalPath="/de/"
  hideNav
  hideFooter
>
  <MinimalLanding locale="de" />
</BaseLayout>
