---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getFAQSchema, getBreadcrumbSchema } from '../../lib/seo'
import de from '../../i18n/de.json'

const faqSchema = getFAQSchema(de.faq.items)
const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Startseite', url: 'https://flexen.app/de/' },
  { name: 'Preise', url: 'https://flexen.app/de/preise' },
])
---

<BaseLayout
  title="Preise — Flexen"
  description="Flexen kostenlos nutzen oder Premium freischalten: unbegrenzte KI, Essenserkennung, erweiterte Analysen. Ab 5,99 €/Monat."
  locale="de"
  canonicalPath="/de/preise"
  schema={[faqSchema, breadcrumbSchema]}
>
  <!-- Hero -->
  <section class="section gradient-hero pt-32 pb-12">
    <div class="container">
      <div class="content text-center">
        <h1 class="reveal mb-4 text-[length:var(--text-h1)] font-bold">
          {de.pricing.sectionTitle}
        </h1>
        <p class="text-secondary reveal text-body mx-auto mb-12 max-w-2xl">
          {de.pricing.sectionSubtitle}
        </p>

        <!-- Billing Toggle -->
        <div class="reveal mb-16 flex items-center justify-center gap-4" id="billing-toggle">
          <span class="text-tertiary text-body font-medium transition-colors duration-300" data-toggle-label="monthly">
            {de.pricing.toggle.monthly}
          </span>
          <button
            type="button"
            class="gradient-accent focus:ring-flexen-accent/50 relative h-8 w-16 rounded-full p-1 transition-all duration-300 focus:ring-2 focus:outline-none"
            id="toggle-switch"
            aria-label="Abrechnungszeitraum wechseln"
            data-active="yearly"
          >
            <span
              class="block h-6 w-6 translate-x-8 rounded-full bg-white transition-transform duration-300"
              id="toggle-knob"></span>
          </button>
          <span class="text-body font-medium text-white transition-colors duration-300" data-toggle-label="yearly">
            {de.pricing.toggle.yearly}
          </span>
          <span class="gradient-accent inline-block rounded-full px-3 py-1 text-xs font-semibold text-white">
            {de.pricing.toggle.yearlyBadge}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="section pt-0">
    <div class="container">
      <div class="content">
        <div class="stagger-children mx-auto grid max-w-4xl grid-cols-1 gap-8 md:grid-cols-2">
          <!-- Free Plan -->
          <div class="gradient-card card-hover flex flex-col rounded-2xl border border-white/5 p-8 text-left">
            <h2 class="mb-1 text-[length:var(--text-h3)] font-bold">{de.pricing.free.name}</h2>
            <p class="text-tertiary mb-6">{de.pricing.free.subtitle}</p>
            <div class="mb-6">
              <span class="text-[length:var(--text-h1)] font-bold">{de.pricing.free.price}&euro;</span>
              <span class="text-tertiary ml-2">{de.pricing.free.period}</span>
            </div>
            <a
              href="#"
              class="mb-8 block w-full rounded-xl border border-white/10 py-3 text-center font-medium text-white transition-colors hover:bg-white/5"
            >
              {de.pricing.free.cta}
            </a>
            <ul class="flex-1 space-y-3">
              {
                de.pricing.free.features.map((f) => (
                  <li class="text-secondary flex items-start gap-3">
                    <span class="text-success mt-0.5 shrink-0">&#10003;</span>
                    <span>{f}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Premium Plan -->
          <div
            class="border-flexen-accent gradient-card card-hover relative flex flex-col rounded-2xl border-2 p-8 text-left"
          >
            <span
              class="gradient-accent absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-4 py-1 text-xs font-semibold text-white"
            >
              {de.pricing.premium.popular}
            </span>
            <h2 class="mb-1 text-[length:var(--text-h3)] font-bold">{de.pricing.premium.name}</h2>
            <p class="text-tertiary mb-6">{de.pricing.premium.subtitle}</p>
            <div class="mb-6">
              <span
                class="text-[length:var(--text-h1)] font-bold"
                id="premium-price"
                data-price-monthly={de.pricing.premium.priceMonthly}
                data-price-yearly={de.pricing.premium.priceYearly}
                data-currency="€"
              >
                {de.pricing.premium.priceYearly}&euro;
              </span>
              <span class="text-tertiary ml-2">{de.pricing.premium.period}</span>
            </div>
            <div class="mb-8">
              <span class="text-tertiary text-[length:var(--text-small)] line-through" id="premium-compare">
                {de.pricing.premium.priceMonthly}&euro;/Monat
              </span>
            </div>
            <a
              href="#"
              class="btn-glow gradient-accent mb-8 block w-full rounded-xl py-3 text-center font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
            >
              {de.pricing.premium.cta}
            </a>
            <ul class="flex-1 space-y-3">
              {
                de.pricing.premium.features.map((f) => (
                  <li class="text-secondary flex items-start gap-3">
                    <span class="text-success mt-0.5 shrink-0">&#10003;</span>
                    <span>{f}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- Guarantee -->
        <p class="text-tertiary reveal mt-8 text-center">
          <svg
            class="text-success mr-2 inline-block h-5 w-5 align-text-bottom"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            ></path>
          </svg>
          {de.pricing.guarantee}
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <div class="content mx-auto max-w-3xl">
        <h2 class="reveal mb-16 text-center text-[length:var(--text-h2)] font-bold">
          {de.faq.sectionTitle}
        </h2>
        <div class="stagger-children space-y-4">
          {
            de.faq.items.map((item) => (
              <details class="group gradient-card cursor-pointer rounded-2xl border border-white/5 p-6">
                <summary class="text-body flex list-none items-center justify-between font-semibold">
                  {item.question}
                  <span class="text-flexen-accent text-xl transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="text-secondary text-body mt-4 border-t border-white/5 pt-4">{item.answer}</p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section gradient-hero">
    <div class="container">
      <div class="content text-center">
        <h2 class="reveal mb-6 text-[length:var(--text-h1)] font-bold">
          {de.finalCta.headline}
        </h2>
        <p class="text-secondary reveal text-body mx-auto mb-8">
          {de.finalCta.subline}
        </p>
        <a
          href="#"
          class="btn-glow gradient-accent reveal inline-flex items-center justify-center rounded-xl px-10 py-4 text-lg font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
        >
          {de.finalCta.cta}
        </a>
      </div>
    </div>
  </section>

  <!-- Pricing Toggle Script -->
  <script>
    function initPricingToggle() {
      const toggleSwitch = document.getElementById('toggle-switch')
      const toggleKnob = document.getElementById('toggle-knob')
      const premiumPrice = document.getElementById('premium-price')
      const premiumCompare = document.getElementById('premium-compare')
      const monthlyLabel = document.querySelector('[data-toggle-label="monthly"]')
      const yearlyLabel = document.querySelector('[data-toggle-label="yearly"]')

      if (!toggleSwitch || !toggleKnob || !premiumPrice) return

      function setYearly() {
        toggleSwitch.dataset.active = 'yearly'
        toggleKnob.style.transform = 'translateX(2rem)'
        premiumPrice.textContent = premiumPrice.dataset.priceYearly + '\u20AC'
        if (premiumCompare) premiumCompare.style.display = ''
        if (monthlyLabel) monthlyLabel.classList.replace('text-white', 'text-tertiary')
        if (yearlyLabel) yearlyLabel.classList.replace('text-tertiary', 'text-white')
      }

      function setMonthly() {
        toggleSwitch.dataset.active = 'monthly'
        toggleKnob.style.transform = 'translateX(0)'
        premiumPrice.textContent = premiumPrice.dataset.priceMonthly + '\u20AC'
        if (premiumCompare) premiumCompare.style.display = 'none'
        if (monthlyLabel) monthlyLabel.classList.replace('text-tertiary', 'text-white')
        if (yearlyLabel) yearlyLabel.classList.replace('text-white', 'text-tertiary')
      }

      toggleSwitch.addEventListener('click', () => {
        if (toggleSwitch.dataset.active === 'yearly') {
          setMonthly()
        } else {
          setYearly()
        }
      })

      // Default to yearly
      setYearly()
    }

    // Run on load and after Astro page transitions
    initPricingToggle()
    document.addEventListener('astro:after-swap', initPricingToggle)
  </script>
</BaseLayout>
