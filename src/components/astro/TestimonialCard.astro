---
interface Props {
  name: string
  role: string
  text: string
  result: string
  class?: string
}

const { name, role, text, result, class: className = '' } = Astro.props

const initial = name.charAt(0).toUpperCase()
---

<div class:list={['p-8 rounded-2xl gradient-card border border-white/5 card-hover flex flex-col', className]}>
  <p class="text-secondary text-[length:var(--text-body)] mb-6 italic flex-1">&ldquo;{text}&rdquo;</p>
  <div class="flex items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-flexen-accent/20 border border-flexen-accent/30 flex items-center justify-center text-flexen-accent font-bold text-sm font-heading shrink-0" aria-hidden="true">
        {initial}
      </div>
      <div class="min-w-0">
        <span class="font-semibold block truncate">{name}</span>
        <span class="text-tertiary text-[length:var(--text-small)] block truncate">{role}</span>
      </div>
    </div>
    <span class="inline-flex items-center px-3 py-1 rounded-full bg-success/15 text-success font-semibold text-[length:var(--text-caption)] whitespace-nowrap shrink-0">
      {result}
    </span>
  </div>
</div>
