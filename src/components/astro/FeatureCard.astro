---
interface Props {
  title: string
  description: string
  badge?: string
  badgeColor?: 'accent' | 'success' | 'warning'
  colSpan?: 1 | 2
  class?: string
}

const { title, description, badge, badgeColor = 'accent', colSpan = 1, class: className = '' } = Astro.props

const badgeColors = {
  accent: 'gradient-accent text-white',
  success: 'bg-success/20 text-success',
  warning: 'bg-warning/20 text-warning',
}

const spanClass = colSpan === 2 ? 'md:col-span-2 lg:col-span-2' : ''
---

<div
  class:list={[
    'group gradient-card card-hover gradient-border relative rounded-2xl border border-white/5 p-8',
    spanClass,
    className,
  ]}
>
  {
    badge && (
      <span class:list={['mb-4 inline-block rounded-full px-3 py-1 text-xs font-medium', badgeColors[badgeColor]]}>
        {badge}
      </span>
    )
  }
  <h3 class="font-heading mb-3 text-h3 font-bold">{title}</h3>
  <p class="text-secondary text-body">{description}</p>
  <slot />
</div>
