---
interface Props {
  title: string
  description: string
  badge?: string
  badgeColor?: 'accent' | 'success' | 'warning'
  colSpan?: 1 | 2
  class?: string
}

const {
  title,
  description,
  badge,
  badgeColor = 'accent',
  colSpan = 1,
  class: className = '',
} = Astro.props

const badgeColors = {
  accent: 'gradient-accent text-white',
  success: 'bg-success/20 text-success',
  warning: 'bg-warning/20 text-warning',
}

const spanClass = colSpan === 2 ? 'md:col-span-2 lg:col-span-2' : ''
---

<div class:list={['group relative p-8 rounded-2xl gradient-card border border-white/5 card-hover gradient-border', spanClass, className]}>
  {badge && (
    <span class:list={['inline-block px-3 py-1 rounded-full text-xs font-medium mb-4', badgeColors[badgeColor]]}>
      {badge}
    </span>
  )}
  <h3 class="text-[length:var(--text-h3)] font-bold mb-3 font-heading">{title}</h3>
  <p class="text-secondary text-[length:var(--text-body)]">{description}</p>
  <slot />
</div>
