---
import { t, localePath, altLocale } from '../../lib/i18n'
import de from '../../i18n/de.json'
import en from '../../i18n/en.json'

interface Props {
  locale: 'de' | 'en'
}

const { locale } = Astro.props
const content = locale === 'de' ? de : en
---

<footer class="py-16 border-t border-white/5">
  <div class="container">
    <div class="content">
      <!-- Flexen Logo Text -->
      <div class="mb-12">
        <a href={localePath(locale, '/')} class="text-2xl font-bold font-heading tracking-tight">
          <span class="text-accent">F</span><span class="text-white">lexen</span>
        </a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
        <!-- Product -->
        <div>
          <h4 class="font-semibold mb-4 font-heading">{content.footer.product.title}</h4>
          <ul class="space-y-2 text-secondary text-sm">
            <li><a href={localePath(locale, '/features')} class="hover:text-white transition-colors">{content.footer.product.features}</a></li>
            <li><a href={localePath(locale, locale === 'de' ? '/preise' : '/pricing')} class="hover:text-white transition-colors">{content.footer.product.pricing}</a></li>
            <li><a href={localePath(locale, '/blog')} class="hover:text-white transition-colors">{content.footer.product.blog}</a></li>
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h4 class="font-semibold mb-4 font-heading">{content.footer.company.title}</h4>
          <ul class="space-y-2 text-secondary text-sm">
            <li><a href={localePath(locale, locale === 'de' ? '/ueber-uns' : '/about')} class="hover:text-white transition-colors">{content.footer.company.about}</a></li>
            <li><a href="#" class="hover:text-white transition-colors">{content.footer.company.careers}</a></li>
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h4 class="font-semibold mb-4 font-heading">{content.footer.legal.title}</h4>
          <ul class="space-y-2 text-secondary text-sm">
            <li><a href={localePath(locale, locale === 'de' ? '/impressum' : '/imprint')} class="hover:text-white transition-colors">{content.footer.legal.imprint}</a></li>
            <li><a href={localePath(locale, locale === 'de' ? '/datenschutz' : '/privacy')} class="hover:text-white transition-colors">{content.footer.legal.privacy}</a></li>
            <li><a href="#" class="hover:text-white transition-colors">{content.footer.legal.terms}</a></li>
          </ul>
        </div>

        <!-- Download -->
        <div>
          <h4 class="font-semibold mb-4 font-heading">{content.footer.social.title}</h4>
          <!-- App Store Badges & Social links placeholder -->
        </div>
      </div>

      <div class="text-center text-tertiary text-sm border-t border-white/5 pt-8">
        <p>{content.footer.copyright}</p>
        <p class="mt-2">{content.footer.madeWith}</p>
      </div>
    </div>
  </div>
</footer>
