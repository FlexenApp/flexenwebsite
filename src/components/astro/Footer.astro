---
import { t, localePath, altLocale } from '../../lib/i18n'
import AppStoreBadges from './AppStoreBadges.astro'
import de from '../../i18n/de.json'
import en from '../../i18n/en.json'

interface Props {
  locale: 'de' | 'en'
}

const { locale } = Astro.props
const content = locale === 'de' ? de : en
---

<footer class="border-t border-white/5 py-16">
  <div class="container">
    <div class="content">
      <!-- Flexen Logo Text -->
      <div class="mb-12">
        <a href={localePath(locale, '/')} class="font-heading text-2xl font-bold tracking-tight">
          <span class="text-flexen-accent">F</span><span class="text-white">lexen</span>
        </a>
      </div>

      <div class="mb-12 grid grid-cols-2 gap-8 md:grid-cols-4">
        <!-- Product -->
        <div>
          <h4 class="font-heading mb-4 font-semibold">{content.footer.product.title}</h4>
          <ul class="text-secondary space-y-2 text-sm">
            <li>
              <a href={localePath(locale, '/features')} class="transition-colors hover:text-white"
                >{content.footer.product.features}</a>
            </li>
            <li>
              <a
                href={localePath(locale, locale === 'de' ? '/preise' : '/pricing')}
                class="transition-colors hover:text-white">{content.footer.product.pricing}</a>
            </li>
            <li>
              <a href={localePath(locale, '/blog')} class="transition-colors hover:text-white"
                >{content.footer.product.blog}</a>
            </li>
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h4 class="font-heading mb-4 font-semibold">{content.footer.company.title}</h4>
          <ul class="text-secondary space-y-2 text-sm">
            <li>
              <a
                href={localePath(locale, locale === 'de' ? '/ueber-uns' : '/about')}
                class="transition-colors hover:text-white">{content.footer.company.about}</a>
            </li>
            <li><a href="#" class="transition-colors hover:text-white">{content.footer.company.careers}</a></li>
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h4 class="font-heading mb-4 font-semibold">{content.footer.legal.title}</h4>
          <ul class="text-secondary space-y-2 text-sm">
            <li>
              <a
                href={localePath(locale, locale === 'de' ? '/impressum' : '/imprint')}
                class="transition-colors hover:text-white">{content.footer.legal.imprint}</a>
            </li>
            <li>
              <a
                href={localePath(locale, locale === 'de' ? '/datenschutz' : '/privacy')}
                class="transition-colors hover:text-white">{content.footer.legal.privacy}</a>
            </li>
            <li><a href="#" class="transition-colors hover:text-white">{content.footer.legal.terms}</a></li>
          </ul>
        </div>

        <!-- Download -->
        <div>
          <h4 class="font-heading mb-4 font-semibold">{locale === 'de' ? 'App laden' : 'Download'}</h4>
          <AppStoreBadges locale={locale} size="sm" campaign="footer" />
        </div>
      </div>

      <div class="text-tertiary border-t border-white/5 pt-8 text-center text-sm">
        <p>{content.footer.copyright}</p>
        <p class="mt-2">{content.footer.madeWith}</p>
      </div>
    </div>
  </div>
</footer>
