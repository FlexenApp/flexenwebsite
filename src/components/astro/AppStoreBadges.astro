---
interface Props {
  locale?: 'de' | 'en'
  class?: string
  size?: 'sm' | 'md'
  campaign?: string
}

const { locale = 'de', class: className = '', size = 'md', campaign = 'website' } = Astro.props

const iosUrl = `https://apps.apple.com/app/flexen/id0000000000?utm_source=website&utm_medium=badge&utm_campaign=${campaign}`
const androidUrl = `https://play.google.com/store/apps/details?id=com.flexen.app&utm_source=website&utm_medium=badge&utm_campaign=${campaign}`

const newWindowHint = locale === 'de' ? '(öffnet in neuem Fenster)' : '(opens in new window)'
const iosAlt = `${locale === 'de' ? 'Im App Store laden' : 'Download on the App Store'} ${newWindowHint}`
const androidAlt = `${locale === 'de' ? 'Jetzt bei Google Play' : 'Get it on Google Play'} ${newWindowHint}`

const badgeHeight = size === 'sm' ? 'h-10' : 'h-12'
---

<div class:list={['flex items-center gap-3', className]}>
  <a
    href={iosUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block transition-transform hover:scale-105 active:scale-95"
    aria-label={iosAlt}
  >
    <div class:list={['flex items-center gap-2 rounded-lg bg-white/10 border border-white/10 px-4', badgeHeight, 'hover:bg-white/15 transition-colors']}>
      <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
      <div class="text-left" aria-hidden="true">
        <div class="text-[9px] text-white/70 leading-none">{locale === 'de' ? 'Laden im' : 'Download on the'}</div>
        <div class="text-sm font-semibold text-white leading-tight">App Store</div>
      </div>
    </div>
  </a>

  <a
    href={androidUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block transition-transform hover:scale-105 active:scale-95"
    aria-label={androidAlt}
  >
    <div class:list={['flex items-center gap-2 rounded-lg bg-white/10 border border-white/10 px-4', badgeHeight, 'hover:bg-white/15 transition-colors']}>
      <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M3.18 23.27L14.45 12 3.18.73a1.2 1.2 0 00-.18.64v21.26c0 .24.06.46.18.64zm1.46 1.16L16.62 18l-3.21-3.21-8.77 8.77.01.87zm12.06-9.71l3.15-1.82a1.2 1.2 0 000-2.08l-3.15-1.82-3.5 3.5 3.5 3.5-.01-1.28zM4.64-.43L13.41 8.34l3.21-3.21L4.64-.43z"/>
      </svg>
      <div class="text-left" aria-hidden="true">
        <div class="text-[9px] text-white/70 leading-none">{locale === 'de' ? 'Jetzt bei' : 'Get it on'}</div>
        <div class="text-sm font-semibold text-white leading-tight">Google Play</div>
      </div>
    </div>
  </a>
</div>
