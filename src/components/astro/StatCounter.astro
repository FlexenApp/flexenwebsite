---
interface Props {
  value: string
  suffix?: string
  label: string
  class?: string
}

const { value, suffix = '', label, class: className = '' } = Astro.props
---

<div class:list={['text-center', className]}>
  <span
    class="text-flexen-accent font-heading block text-h1 font-bold tabular-nums"
    data-count-target={value}
    data-count-suffix={suffix}
    aria-label={`${value}${suffix}`}
  >
    {value}{suffix}
  </span>
  <span class="text-secondary text-body mt-1 block">{label}</span>
</div>
