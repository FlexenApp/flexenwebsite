---
import { t, localePath, altLocale } from '../../lib/i18n'

interface Props {
  locale: 'de' | 'en'
  currentPath?: string
}

const { locale, currentPath = '' } = Astro.props
const alt = altLocale(locale)
const pathWithoutLocale = currentPath.replace(/^\/(de|en)/, '')

const navItems = [
  { label: t(locale, 'nav.features'), href: localePath(locale, '/features') },
  { label: t(locale, 'nav.pricing'), href: localePath(locale, locale === 'de' ? '/preise' : '/pricing') },
  { label: t(locale, 'nav.blog'), href: localePath(locale, '/blog') },
  { label: t(locale, 'nav.about'), href: localePath(locale, locale === 'de' ? '/ueber-uns' : '/about') },
]

/**
 * Check if a nav item matches the current path for active state highlighting.
 * Matches exact path or any sub-path (e.g. /de/blog matches /de/blog/post-slug).
 */
function isActive(href: string): boolean {
  if (!currentPath) return false
  // Normalize: remove trailing slashes for comparison
  const normalizedCurrent = currentPath.replace(/\/$/, '')
  const normalizedHref = href.replace(/\/$/, '')
  return normalizedCurrent === normalizedHref || normalizedCurrent.startsWith(normalizedHref + '/')
}
---

<nav id="main-nav" class="fixed top-0 right-0 left-0 z-50 transition-all duration-300">
  <div class="container">
    <div class="flex h-16 items-center justify-between md:h-20">
      <!-- Logo -->
      <a href={localePath(locale, '/')} class="font-heading flex items-center gap-2 text-xl font-bold">
        <span class="text-flexen-accent">F</span>
        <span>lexen</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden items-center gap-8 md:flex">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium transition-colors',
                isActive(item.href) ? 'text-white' : 'text-secondary hover:text-white',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }

        <!-- Language Switch -->
        <a
          href={`/${alt}${pathWithoutLocale}`}
          class="text-tertiary text-sm font-medium uppercase transition-colors hover:text-white"
        >
          {alt.toUpperCase()}
        </a>

        <!-- CTA -->
        <a
          href="#"
          class="gradient-accent rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-transform hover:scale-[1.02] active:scale-[0.97]"
        >
          {t(locale, 'nav.cta')}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="flex flex-col gap-1.5 p-2 md:hidden" aria-label="Menu" aria-expanded="false">
        <span class="h-0.5 w-6 origin-center bg-white transition-transform" id="hamburger-top"></span>
        <span class="h-0.5 w-6 bg-white transition-opacity" id="hamburger-mid"></span>
        <span class="h-0.5 w-6 origin-center bg-white transition-transform" id="hamburger-bot"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="bg-flexen-dark/95 fixed inset-0 top-16 -translate-x-full backdrop-blur-lg transition-transform duration-300 ease-[var(--ease-default)] md:hidden"
  >
    <div class="container flex flex-col gap-6 py-8">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            data-close-menu
            class:list={[
              'text-2xl font-semibold transition-colors',
              isActive(item.href) ? 'text-white' : 'text-secondary hover:text-white',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
      <hr class="border-white/10" />
      <a
        href={`/${alt}${pathWithoutLocale}`}
        data-close-menu
        class="text-tertiary text-lg uppercase transition-colors hover:text-white"
      >
        {alt.toUpperCase()}
      </a>
      <a
        href="#"
        data-close-menu
        class="gradient-accent mt-4 block rounded-xl py-3 text-center font-semibold text-white"
      >
        {t(locale, 'nav.cta')}
      </a>
    </div>
  </div>
</nav>

<!-- Nav scroll behavior + mobile toggle -->
<script>
  const nav = document.getElementById('main-nav')
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  const top = document.getElementById('hamburger-top')
  const mid = document.getElementById('hamburger-mid')
  const bot = document.getElementById('hamburger-bot')

  let isOpen = false

  function closeMenu() {
    if (!isOpen) return
    isOpen = false
    menu?.classList.add('-translate-x-full')
    menu?.classList.remove('translate-x-0')
    top?.classList.remove('rotate-45', 'translate-y-[4px]')
    mid?.classList.remove('opacity-0')
    bot?.classList.remove('-rotate-45', '-translate-y-[4px]')
    btn?.setAttribute('aria-expanded', 'false')
    document.body.style.overflow = ''
  }

  function openMenu() {
    isOpen = true
    menu?.classList.remove('-translate-x-full')
    menu?.classList.add('translate-x-0')
    top?.classList.add('rotate-45', 'translate-y-[4px]')
    mid?.classList.add('opacity-0')
    bot?.classList.add('-rotate-45', '-translate-y-[4px]')
    btn?.setAttribute('aria-expanded', 'true')
    document.body.style.overflow = 'hidden'
  }

  // Scroll: transparent -> solid
  let lastScroll = 0
  window.addEventListener(
    'scroll',
    () => {
      const scrollY = window.scrollY
      if (scrollY > 80) {
        nav?.classList.add('bg-flexen-dark/90', 'backdrop-blur-lg', 'border-b', 'border-white/5')
      } else {
        nav?.classList.remove('bg-flexen-dark/90', 'backdrop-blur-lg', 'border-b', 'border-white/5')
      }
      lastScroll = scrollY
    },
    { passive: true },
  )

  // Mobile toggle
  btn?.addEventListener('click', () => {
    if (isOpen) {
      closeMenu()
    } else {
      openMenu()
    }
  })

  // Close menu when any link with data-close-menu is clicked
  document.querySelectorAll('[data-close-menu]').forEach((link) => {
    link.addEventListener('click', () => {
      closeMenu()
    })
  })
</script>

<!-- Spacer for fixed nav -->
<div class="h-16 md:h-20"></div>
