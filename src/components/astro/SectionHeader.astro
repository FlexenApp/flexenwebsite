---
interface Props {
  title: string
  subtitle?: string
  align?: 'center' | 'left'
  class?: string
}

const { title, subtitle, align = 'center', class: className = '' } = Astro.props

const alignClasses = align === 'center' ? 'text-center' : 'text-left'
const subtitleMargin = align === 'center' ? 'mx-auto' : ''
---

<div class:list={['mb-16', alignClasses, className]}>
  <h2 class="reveal font-heading mb-4 text-h2 font-bold">{title}</h2>
  {subtitle && <p class:list={['text-secondary reveal text-body max-w-2xl', subtitleMargin]}>{subtitle}</p>}
</div>
