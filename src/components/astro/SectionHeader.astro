---
interface Props {
  title: string
  subtitle?: string
  align?: 'center' | 'left'
  class?: string
}

const { title, subtitle, align = 'center', class: className = '' } = Astro.props

const alignClasses = align === 'center' ? 'text-center' : 'text-left'
const subtitleMargin = align === 'center' ? 'mx-auto' : ''
---

<div class:list={['mb-16', alignClasses, className]}>
  <h2 class="text-[length:var(--text-h2)] font-bold mb-4 reveal font-heading">{title}</h2>
  {subtitle && (
    <p class:list={['text-secondary text-[length:var(--text-body)] max-w-2xl reveal', subtitleMargin]}>
      {subtitle}
    </p>
  )}
</div>
