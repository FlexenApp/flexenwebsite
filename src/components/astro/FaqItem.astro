---
interface Props {
  question: string
  answer: string
}

const { question, answer } = Astro.props
---

<details class="group p-6 rounded-2xl gradient-card border border-white/5 cursor-pointer">
  <summary class="flex items-center justify-between font-semibold text-[length:var(--text-body)] list-none">
    {question}
    <span class="text-flexen-accent transition-transform group-open:rotate-45 text-xl flex-shrink-0 ml-4">+</span>
  </summary>
  <p class="text-secondary text-[length:var(--text-body)] mt-4 pt-4 border-t border-white/5">
    {answer}
  </p>
</details>
