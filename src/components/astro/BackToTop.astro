---
/**
 * Back to Top Button
 * Fixed button in the bottom-right corner.
 * Appears after scrolling 500px. Smooth scrolls to top on click.
 * Integrates with Lenis for smooth scroll.
 * Respects prefers-reduced-motion.
 */
---

<button
  id="back-to-top"
  class="bg-white focus-visible:outline-flexen-accent pointer-events-none fixed right-6 bottom-6 z-50 flex h-11 w-11 scale-90 cursor-pointer items-center justify-center rounded-full border border-border text-text-secondary opacity-0 shadow-lg transition-all duration-300 ease-[var(--ease-default)] hover:border-flexen-accent hover:text-flexen-accent hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2"
  aria-label="Zurück nach oben"
  type="button"
>
  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path
      d="M10 16V4M10 4L4 10M10 4L16 10"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
</button>

<script>
  import { lenisInstance } from '../../lib/smooth-scroll'

  function initBackToTop() {
    const btn = document.getElementById('back-to-top') as HTMLButtonElement | null
    if (!btn) return

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    // Hide entirely for reduced-motion users (they have native scroll-to-top via browser)
    if (reducedMotion) {
      btn.style.display = 'none'
      return
    }

    let isVisible = false

    function updateVisibility() {
      const shouldShow = window.scrollY > 500

      if (shouldShow && !isVisible) {
        isVisible = true
        btn!.classList.remove('opacity-0', 'scale-90', 'pointer-events-none')
        btn!.classList.add('opacity-100', 'scale-100', 'pointer-events-auto')
      } else if (!shouldShow && isVisible) {
        isVisible = false
        btn!.classList.add('opacity-0', 'scale-90', 'pointer-events-none')
        btn!.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto')
      }
    }

    // Use Lenis scroll event if available, else native
    if (lenisInstance) {
      lenisInstance.on('scroll', () => {
        updateVisibility()
      })
    } else {
      window.addEventListener('scroll', updateVisibility, { passive: true })
    }

    // Scroll to top on click
    btn.addEventListener('click', () => {
      if (lenisInstance) {
        lenisInstance.scrollTo(0, { duration: 1.2 })
      } else {
        window.scrollTo({ top: 0, behavior: 'smooth' })
      }
    })

    // Initial state
    updateVisibility()
  }

  // Run on initial load
  initBackToTop()

  // Re-run after Astro View Transitions navigation
  document.addEventListener('astro:after-swap', initBackToTop)
</script>
